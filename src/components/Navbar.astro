---
const ticketUrl = "https://www.eventbrite.com/e/all-american-countdown-250-ball-tickets-1982528927390";
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/countdown250/" class="flex-shrink-0">
        <img
          src="/countdown250/images/logos/countdown250-logo.png"
          alt="All-American Countdown 250 Ball"
          class="h-14 w-auto"
        />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#about" class="text-white/90 hover:text-white text-sm font-medium tracking-wide uppercase transition-colors">About</a>
        <a href="#experience" class="text-white/90 hover:text-white text-sm font-medium tracking-wide uppercase transition-colors">Experience</a>
        <a href="#venue" class="text-white/90 hover:text-white text-sm font-medium tracking-wide uppercase transition-colors">Venue</a>
        <a href="#tickets" class="text-white/90 hover:text-white text-sm font-medium tracking-wide uppercase transition-colors">Tickets</a>
        <a
          href={ticketUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-red text-white px-6 py-2.5 text-sm font-semibold tracking-wider uppercase hover:bg-red-light transition-colors rounded"
        >
          Buy Tickets
        </a>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden text-white p-2" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-navy-dark/95 backdrop-blur-sm">
    <div class="px-4 py-6 space-y-4">
      <a href="#about" class="block text-white/90 hover:text-white text-sm font-medium tracking-wide uppercase">About</a>
      <a href="#experience" class="block text-white/90 hover:text-white text-sm font-medium tracking-wide uppercase">Experience</a>
      <a href="#venue" class="block text-white/90 hover:text-white text-sm font-medium tracking-wide uppercase">Venue</a>
      <a href="#tickets" class="block text-white/90 hover:text-white text-sm font-medium tracking-wide uppercase">Tickets</a>
      <a
        href={ticketUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="block bg-red text-white px-6 py-3 text-sm font-semibold tracking-wider uppercase text-center hover:bg-red-light transition-colors rounded"
      >
        Buy Tickets
      </a>
    </div>
  </div>
</nav>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      navbar?.classList.add('bg-navy-dark/95', 'backdrop-blur-sm', 'shadow-lg');
      navbar?.classList.remove('bg-transparent');
    } else {
      navbar?.classList.remove('bg-navy-dark/95', 'backdrop-blur-sm', 'shadow-lg');
      navbar?.classList.add('bg-transparent');
    }
  });

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
