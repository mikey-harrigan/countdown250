---
const heroImages = [
  { src: "/countdown250/images/event-photos/aab-2025-soldier-ceremony.jpg", alt: "Decorated soldier receiving All-American Hero award", caption: "Hero Awards Ceremony" },
  { src: "/countdown250/images/event-photos/aab-2025-medal-recipients-stage.jpg", alt: "Medal recipients on stage at the 2025 Ball", caption: "Medal Recipients" },
  { src: "/countdown250/images/event-photos/aab-2025-soldier-crowd-emotional.jpg", alt: "Emotional moment during hero recognition", caption: "Honoring Service & Sacrifice" },
  { src: "/countdown250/images/event-photos/aab-2025-vip-group-formal.jpg", alt: "VIP group with honorees at the 2025 Ball", caption: "Distinguished Honorees" },
];
---

<section id="heroes" class="py-20 sm:py-28 bg-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-3">Honoring Those Who Serve</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-6">Your All-American Heroes</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-6"></div>
      <div class="text-slate/70 text-lg max-w-3xl mx-auto space-y-4">
        <p>
          America's greatness is embodied by the selfless citizens who dedicate their lives to
          serving others. These extraordinary Americans inspire us through their remarkable
          stories, as well as their daily acts of courage and unwavering commitment to making our
          nation stronger.
        </p>
        <p>
          At the All-American Countdown 250 Ball we are honored to recognize several
          "All-American Heroes" for their lifetime of contributions in their respective
          fields of service.
        </p>
      </div>
    </div>

    <!-- Hero ceremony photos -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {heroImages.map((img) => (
        <div class="group relative overflow-hidden rounded-xl aspect-[3/4]">
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-navy/70 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4">
            <p class="text-white font-semibold text-sm">{img.caption}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <p class="text-slate/60 text-sm italic">
        2026 honorees will be announced as the event approaches.
      </p>
    </div>
  </div>
</section>
