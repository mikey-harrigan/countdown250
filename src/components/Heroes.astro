---
const heroes = [
  { name: "Buzz Aldrin", title: "Apollo 11 Astronaut", image: "/countdown250/images/honorees/buzz-aldrin-portrait.jpg" },
  { name: "Lee Greenwood", title: "Legendary Patriotic Performer", image: "/countdown250/images/honorees/lee-greenwood.jpg" },
  { name: "Luis Avila", title: "Wounded Warrior & Advocate", image: "/countdown250/images/honorees/luis-avila.jpg" },
  { name: "Sheriff Mark Chapman", title: "Community Leader & Hero", image: "/countdown250/images/honorees/sheriff-chapman.png" },
];
---

<section id="heroes" class="py-20 sm:py-28 bg-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-3">Honoring Those Who Serve</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-6">Your All-American Heroes</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-6"></div>
      <p class="text-slate/70 text-lg max-w-2xl mx-auto">
        Each year, the All-American Ball honors extraordinary Americans who have dedicated their
        lives to service, sacrifice, and making our nation stronger. Past recipients include
        astronauts, veterans, first responders, and community leaders.
      </p>
    </div>

    <!-- Hero honoree grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {heroes.map((hero) => (
        <div class="text-center group">
          <div class="relative overflow-hidden rounded-xl mb-4 aspect-[3/4]">
            <img
              src={hero.image}
              alt={hero.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-navy/60 to-transparent"></div>
          </div>
          <h3 class="font-bold text-navy text-lg">{hero.name}</h3>
          <p class="text-slate/60 text-sm">{hero.title}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <p class="text-slate/60 text-sm italic">
        2026 honorees will be announced as the event approaches.
      </p>
    </div>
  </div>
</section>
