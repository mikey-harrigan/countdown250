---
const ticketUrl = "https://www.eventbrite.com/e/all-american-countdown-250-ball-tickets-1982528927390";

const tickets = [
  {
    name: "Liberty Ticket",
    time: "The Ball: 9 PM – 1 AM",
    price: "$195",
    futurePrice: "$295 / $395 / $495",
    description: "Best for guests who want the full Ball experience at the most accessible entry point.",
    sections: [
      {
        heading: "Includes The Ball Only (9 PM–1 AM)",
        items: [
          "Admission to the main Ball",
          "Access to 4 grand party areas and 3 dance floors",
          "Open bar all night",
          "Multiple live bands and DJs",
          "Immersive experiences and roaming entertainers",
          "Step-and-repeat access",
          "Patriotic Tribute to America performances",
          "All-American Hero Lifetime Achievement Awards ceremony",
        ],
      },
    ],
    note: "Reception-style Ball with limited seating",
    highlight: false,
    badge: "",
    tier: 1,
  },
  {
    name: "Patriot VIP Ticket",
    time: "VIP Reception + Ball: 7 PM – 1 AM",
    price: "$395",
    futurePrice: "$595 / $795 / $995",
    description: "Best for guests who want early access, dinner, and a more elevated evening from start to finish.",
    sectionIntro: "Includes Two Distinct Experiences: The VIP Reception + The Ball",
    sections: [
      {
        heading: "Part One: VIP Reception (7 PM–9 PM)",
        items: [
          "Early entry beginning at 6:30 PM",
          "Admission to the exclusive VIP Reception",
          "Buffet dinner",
          "Premium open bar",
          "Opportunity to mingle with honored guests, dignitaries, and All-American Heroes",
          "Live entertainment",
          "Immersive experiences and roaming entertainers",
          "Step-and-repeat access",
        ],
      },
      {
        heading: "Part Two: The Ball (9 PM–1 AM)",
        items: [
          "Admission to the main Ball",
          "Access to 4 grand party areas and 3 dance floors",
          "Open bar all night",
          "Multiple live bands and DJs",
          "Immersive experiences, roaming entertainers and step-and-repeat",
          "Patriotic Tribute to America performances",
          "All-American Hero Lifetime Achievement Awards ceremony",
        ],
      },
    ],
    note: "Reception-style Ball with limited seating",
    highlight: false,
    badge: "Tier 2",
    tier: 2,
  },
  {
    name: "Statesman's Concierge Pass",
    time: "Premier Luxury: 7 PM – 1 AM",
    price: "$1,495",
    futurePrice: "$2,500 / $3,500 / $5,000",
    sectionIntro: "Includes Two Distinct Experiences: The VIP Reception + The Ball — Elevated with Exclusive Access, Concierge Service, and Recognition",
    sections: [
      {
        heading: "Part One: VIP Reception (7 PM–9 PM)",
        items: [
          "Early entry beginning at 6:30 PM",
          "Private expedited entrance",
          "Dedicated Ambassador / concierge service",
          "Reserved seating on the Presidential Stage with special guests",
          "Private top-shelf open bars",
          "Premium buffet dinner",
          "Live entertainment",
          "Private immersive experiences and roaming entertainers",
          "Access to exclusive hospitality areas",
          "Access to historic hotel spaces reserved for presidents and dignitaries",
          "Private photographer access",
          "Private step-and-repeat",
          "Premium recognition in the official event program",
          "Stage announcement recognition",
        ],
      },
      {
        heading: "Part Two: The Ball (9 PM–1 AM)",
        items: [
          "Continued concierge-level service throughout the evening",
          "Reserved Presidential Stage seating for the main celebration",
          "Access to all 6 grand party areas and all 4 stages / dance floors",
          "Multiple live bands and DJs",
          "Backstage access",
          "Passed hors d'oeuvres and private dessert bar",
          "Most exclusive vantage points for the main stage performances and ceremonies",
          "All-American Hero Lifetime Achievement Awards ceremony",
          "Patriotic Tribute to America performances",
        ],
      },
      {
        heading: "Additional Benefits",
        items: [
          "Premium limited-edition official event gift",
          "Personal stage announcement recognition",
          "Special recognition in the official event program (lead-time permitting)",
          "Official Statesman's Concierge Pass lanyard",
          "Commemorative official event program",
        ],
      },
    ],
    note: "Extremely limited. Expected to sell out.",
    highlight: true,
    badge: "Tier 3 - Most Popular",
    tier: 3,
  },
];

---

<section id="tickets" class="py-20 sm:py-28 bg-navy-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-3">Early Release Pricing</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-6">Choose Your Experience</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-6"></div>
      <p class="price-warning text-gold font-bold text-lg tracking-wide max-w-xl mx-auto mb-4">
        PRICES WILL INCREASE VERY SOON!
      </p>
      <p class="text-white/60 text-sm max-w-lg mx-auto mb-4">
        Ticket sales are deliberately limited to ensure optimal comfort and an exceptional experience for every guest.
      </p>
      <p class="text-gold/80 text-sm max-w-lg mx-auto mb-6 font-medium">
        ★ Proceeds help support <a href="https://www.operationrenewedhopefoundation.org" target="_blank" rel="noopener noreferrer" class="underline hover:text-gold">Operation Renewed Hope Foundation</a> in their mission to house U.S. Veterans and end veteran homelessness.
      </p>
      <div class="flex items-center justify-center gap-3 flex-wrap">
        {["Liberty", "Patriot VIP", "Statesman's Concierge"].map((name) => (
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold tracking-wide uppercase bg-white/10 text-white/80 border border-white/20">
            {name}
          </span>
        ))}
      </div>
      <p class="text-white/40 text-sm mt-3">3 ticket tiers available</p>
    </div>

    <!-- Ticket tier indicator -->
    <div class="flex items-center justify-center gap-0 mb-12 max-w-4xl mx-auto">
      <div class="flex-1 h-1 bg-white/20 rounded-l-full"></div>
      {[1, 2, 3].map((tier) => (
        <div class="flex flex-col items-center mx-2 sm:mx-4">
          <div class="w-4 h-4 rounded-full border-2 bg-gold border-gold"></div>
        </div>
      ))}
      <div class="flex-1 h-1 bg-white/20 rounded-r-full"></div>
    </div>

    <!-- Main 3 ticket cards -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-10 mb-16">
      {tickets.map((ticket) => (
        <div class={`relative rounded-2xl overflow-hidden flex flex-col ${
          ticket.highlight
            ? 'bg-white text-slate ring-4 ring-gold shadow-2xl scale-[1.03]'
            : 'bg-white/5 border-2 border-white/15 text-white'
        }`}>
          {/* Tier header bar */}
          <div class={`py-2 text-center text-xs font-bold tracking-widest uppercase ${
            ticket.highlight
              ? 'bg-gold text-navy-dark'
              : 'bg-white/10 text-white/60'
          }`}>
            {ticket.badge || `Tier ${ticket.tier}`}
          </div>

          <div class="p-8 flex flex-col flex-grow">
            <div class="mb-6">
              <p class={`text-xs font-medium tracking-wider uppercase mb-2 ${ticket.highlight ? 'text-slate/50' : 'text-white/40'}`}>
                {ticket.time}
              </p>
              <h3 class={`text-2xl font-bold mb-1 ${ticket.highlight ? 'text-navy' : 'text-white'}`}>
                {ticket.name}
              </h3>
            </div>

            <div class="mb-6 pb-6 border-b ${ticket.highlight ? 'border-slate/10' : 'border-white/10'}">
              <div class="flex items-baseline gap-1">
                <span class={`text-4xl font-bold ${ticket.highlight ? 'text-navy' : 'text-white'}`}>
                  {ticket.price}
                </span>
                <span class={`text-sm ${ticket.highlight ? 'text-slate/50' : 'text-white/40'}`}>
                  / early
                </span>
              </div>
              <p class={`text-xs mt-1 ${ticket.highlight ? 'text-slate/40' : 'text-white/30'}`}>
                Future tiers: {ticket.futurePrice}
              </p>
            </div>

            {ticket.description && (
              <p class={`text-sm mb-6 italic ${ticket.highlight ? 'text-slate/60' : 'text-white/50'}`}>
                {ticket.description}
              </p>
            )}

            {ticket.sectionIntro && (
              <p class={`text-xs font-bold tracking-wider uppercase mb-4 ${ticket.highlight ? 'text-navy/70' : 'text-gold/90'}`}>
                {ticket.sectionIntro}
              </p>
            )}

            <div class="space-y-5 mb-8 flex-grow">
              {ticket.sections.map((section, si) => (
                <div>
                  <p class={`text-xs font-bold tracking-wider uppercase mb-2 ${
                    ticket.highlight ? 'text-navy/70' : 'text-gold/90'
                  } ${si > 0 ? 'pt-3 border-t ' + (ticket.highlight ? 'border-slate/10' : 'border-white/10') : ''}`}>
                    {section.heading}
                  </p>
                  <ul class="space-y-2">
                    {section.items.map((f) => (
                      <li class="flex items-start gap-2">
                        <svg class={`w-3.5 h-3.5 mt-0.5 flex-shrink-0 ${ticket.highlight ? 'text-gold' : 'text-gold/80'}`} fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                        </svg>
                        <span class={`text-sm leading-snug ${ticket.highlight ? 'text-slate/80' : 'text-white/70'}`}>{f}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            {ticket.note && (
              <p class={`text-xs mb-4 italic ${ticket.highlight ? 'text-slate/50' : 'text-white/40'}`}>
                {ticket.note}
              </p>
            )}

            <button
              id={`eb-ticket-${ticket.tier}`}
              class={`eventbrite-checkout block w-full text-center py-3.5 px-6 rounded-lg font-semibold text-sm tracking-wider uppercase transition-all hover:-translate-y-0.5 cursor-pointer ${
                ticket.highlight
                  ? 'shadow-lg'
                  : 'bg-white/10 text-white hover:bg-white/20 border border-white/20'
              }`}
              style={ticket.highlight ? 'background-color: #1a56db !important; color: white !important;' : ''}
            >
              Buy Tickets
            </button>
          </div>
        </div>
      ))}
    </div>

    <!-- Sponsorship contact line -->
    <div class="text-center mb-16">
      <p class="text-white/60 text-sm">
        Corporate sponsorship and premium host packages available. Contact us at
        <a href="mailto:CountdownAmerica250@gmail.com" class="text-gold hover:text-gold/80 underline">CountdownAmerica250@gmail.com</a> for details.
      </p>
    </div>

    <!-- Event Info & Disclaimers -->
    <div class="mt-20 pt-12 border-t border-white/10 max-w-3xl mx-auto">
      <div class="mb-10">
        <div class="text-center">
          <h4 class="text-gold font-semibold text-sm tracking-wider uppercase mb-2">Dress Code</h4>
          <p class="text-white/70 text-sm">Black Tie Optional</p>
          <p class="text-white/50 text-xs mt-1">Patriotic flair encouraged!</p>
        </div>
      </div>
      <div class="text-center">
        <p class="text-white/30 text-xs">All sales are final. Full <a href="/faq/#terms" class="text-white/50 underline hover:text-white/70">Terms & Conditions</a> apply.</p>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes price-glow {
    0%, 100% {
      opacity: 0.6;
      text-shadow: none;
    }
    50% {
      opacity: 1;
      text-shadow: 0 0 10px rgba(255, 215, 0, 0.8), 0 0 30px rgba(255, 215, 0, 0.5), 0 0 60px rgba(255, 215, 0, 0.3);
    }
  }
  .price-warning {
    animation: price-glow 2.5s ease-in-out infinite;
  }
</style>
