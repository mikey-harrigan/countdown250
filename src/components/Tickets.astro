---
const ticketUrl = "https://www.eventbrite.com/e/all-american-countdown-250-ball-tickets-1982528927390";

const tickets = [
  {
    name: "Liberty Ticket",
    time: "9 PM - 1 AM",
    price: "$195",
    futurePrice: "$295 / $395 / $495",
    features: [
      "Full access to the Ball",
      "Premium open bar all night",
      "Bands, DJs, and roving entertainers",
      "Interactive attractions",
      "Tribute to America presentation",
      "Hero Awards ceremony",
    ],
    note: "Reception-style event with limited seating",
    highlight: false,
    badge: "",
    tier: 1,
  },
  {
    name: "Patriot VIP",
    time: "7 PM - 1 AM",
    price: "$395",
    futurePrice: "$595 / $795 / $995",
    features: [
      "Everything in Liberty, plus:",
      "VIP Mixer Reception (7-9 PM)",
      "Early entry",
      "Full buffet dinner",
      "Open bar during mixer",
      "Live performances",
      "Mingle with honored guests",
    ],
    note: "",
    highlight: false,
    badge: "Tier 2",
    tier: 2,
  },
  {
    name: "Statesman Concierge",
    time: "7 PM - 1 AM",
    price: "$1,495",
    futurePrice: "$2,500 / $3,500 / $5,000",
    features: [
      "Everything in Patriot VIP, plus:",
      "Dedicated concierge ambassador",
      "Reserved Presidential Stage seating",
      "Private top-shelf bars",
      "Premium VIP buffet reception",
      "Exclusive hospitality areas",
      "Backstage access",
      "Private event photographer",
      "Commemorative gifts & lanyard",
      "Program recognition (photo included)",
      "Stage announcement recognition",
    ],
    note: "Extremely limited. Expected to sell out.",
    highlight: true,
    badge: "Tier 3 - Most Popular",
    tier: 3,
  },
];

const hostPackages = [
  {
    name: "Founders Host Package",
    price: "$12,500",
    features: [
      "3 Statesman Concierge Passes",
      "Half-page program tribute",
      "Multiple stage announcements",
    ],
    tier: 4,
  },
  {
    name: "Presidential Host Package",
    price: "$18,500",
    features: [
      "4 Statesman Concierge Passes",
      "Full-page program tribute",
      "Multiple stage announcements",
    ],
    tier: 5,
  },
];
---

<section id="tickets" class="py-20 sm:py-28 bg-navy-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-3">Early Release Pricing</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-6">Choose Your Experience</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-6"></div>
      <p class="text-white/60 text-base max-w-xl mx-auto">
        Prices increase as the event approaches. Lock in today's rates before they go up.
      </p>
    </div>

    <!-- Ticket tier indicator -->
    <div class="flex items-center justify-center gap-0 mb-12 max-w-4xl mx-auto">
      <div class="flex-1 h-1 bg-white/20 rounded-l-full"></div>
      {[1, 2, 3, 4, 5].map((tier) => (
        <div class="flex flex-col items-center mx-2 sm:mx-4">
          <div class={`w-4 h-4 rounded-full border-2 ${tier <= 3 ? 'bg-gold border-gold' : 'bg-red border-red'}`}></div>
        </div>
      ))}
      <div class="flex-1 h-1 bg-white/20 rounded-r-full"></div>
    </div>

    <!-- Main 3 ticket cards -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-10 mb-16">
      {tickets.map((ticket) => (
        <div class={`relative rounded-2xl overflow-hidden flex flex-col ${
          ticket.highlight
            ? 'bg-white text-slate ring-4 ring-gold shadow-2xl scale-[1.03]'
            : 'bg-white/5 border-2 border-white/15 text-white'
        }`}>
          {/* Tier header bar */}
          <div class={`py-2 text-center text-xs font-bold tracking-widest uppercase ${
            ticket.highlight
              ? 'bg-gold text-navy-dark'
              : 'bg-white/10 text-white/60'
          }`}>
            {ticket.badge || `Tier ${ticket.tier}`}
          </div>

          <div class="p-8 flex flex-col flex-grow">
            <div class="mb-6">
              <p class={`text-xs font-medium tracking-wider uppercase mb-2 ${ticket.highlight ? 'text-slate/50' : 'text-white/40'}`}>
                {ticket.time}
              </p>
              <h3 class={`text-2xl font-bold mb-1 ${ticket.highlight ? 'text-navy' : 'text-white'}`}>
                {ticket.name}
              </h3>
            </div>

            <div class="mb-6 pb-6 border-b ${ticket.highlight ? 'border-slate/10' : 'border-white/10'}">
              <div class="flex items-baseline gap-1">
                <span class={`text-4xl font-bold ${ticket.highlight ? 'text-navy' : 'text-white'}`}>
                  {ticket.price}
                </span>
                <span class={`text-sm ${ticket.highlight ? 'text-slate/50' : 'text-white/40'}`}>
                  / early
                </span>
              </div>
              <p class={`text-xs mt-1 ${ticket.highlight ? 'text-slate/40' : 'text-white/30'}`}>
                Future tiers: {ticket.futurePrice}
              </p>
            </div>

            <ul class="space-y-2.5 mb-8 flex-grow">
              {ticket.features.map((f) => (
                <li class="flex items-start gap-2.5">
                  <svg class={`w-4 h-4 mt-0.5 flex-shrink-0 ${ticket.highlight ? 'text-gold' : 'text-gold/80'}`} fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                  </svg>
                  <span class={`text-sm ${ticket.highlight ? 'text-slate/80' : 'text-white/70'}`}>{f}</span>
                </li>
              ))}
            </ul>

            {ticket.note && (
              <p class={`text-xs mb-4 italic ${ticket.highlight ? 'text-slate/50' : 'text-white/40'}`}>
                {ticket.note}
              </p>
            )}

            <a
              href={ticketUrl}
              target="_blank"
              rel="noopener noreferrer"
              class={`block text-center py-3.5 px-6 rounded-lg font-semibold text-sm tracking-wider uppercase transition-all hover:-translate-y-0.5 ${
                ticket.highlight
                  ? 'bg-red text-white hover:bg-red-light shadow-lg'
                  : 'bg-white/10 text-white hover:bg-white/20 border border-white/20'
              }`}
            >
              Buy Tickets
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Divider between ticket types -->
    <div class="flex items-center gap-4 max-w-3xl mx-auto mb-16">
      <div class="flex-1 h-px bg-gold/30"></div>
      <span class="text-gold font-medium tracking-[0.2em] uppercase text-sm">Premium Packages</span>
      <div class="flex-1 h-px bg-gold/30"></div>
    </div>

    <!-- Host packages - now with clear delineation -->
    <div class="grid sm:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {hostPackages.map((pkg) => (
        <div class="bg-gradient-to-b from-gold/10 to-transparent border-2 border-gold/30 rounded-2xl overflow-hidden">
          {/* Tier header bar */}
          <div class="py-2 text-center text-xs font-bold tracking-widest uppercase bg-gold/20 text-gold">
            Tier {pkg.tier}
          </div>
          <div class="p-8 text-center">
            <h3 class="text-xl font-bold text-gold mb-2">{pkg.name}</h3>
            <p class="text-4xl font-bold text-white mb-6">{pkg.price}</p>
            <ul class="space-y-2 mb-6 text-left max-w-xs mx-auto">
              {pkg.features.map((f) => (
                <li class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gold" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-white/70 text-sm">{f}</span>
                </li>
              ))}
            </ul>
            <a href={ticketUrl} target="_blank" rel="noopener noreferrer" class="inline-block border-2 border-gold text-gold hover:bg-gold hover:text-navy-dark px-8 py-3 rounded-lg text-sm font-semibold tracking-wider uppercase transition-all hover:-translate-y-0.5">
              Inquire
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
