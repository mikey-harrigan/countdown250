---
// Social proof & urgency strip — sits right below the hero to build trust with new visitors
---

<section class="bg-white border-b border-slate-200 py-4 sm:py-5">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Trust signals row -->
    <div class="flex flex-wrap justify-center items-center gap-x-6 sm:gap-x-10 gap-y-3 text-center">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-gold flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <span class="text-navy font-semibold text-sm sm:text-base">30+ Years of Premier Events</span>
      </div>
      <div class="hidden sm:block w-px h-6 bg-slate-300"></div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-red flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        <span class="text-navy font-semibold text-sm sm:text-base">Washington Hilton — Iconic DC Venue</span>
      </div>
      <div class="hidden sm:block w-px h-6 bg-slate-300"></div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
        <span class="text-navy font-semibold text-sm sm:text-base">3,000 Guests Expected</span>
      </div>
    </div>

    <!-- Urgency line -->
    <div class="text-center mt-3 pt-3 border-t border-slate-100">
      <p class="text-red font-semibold text-sm sm:text-base animate-pulse">
        Early pricing available now — rates increase as the event approaches
      </p>
    </div>
  </div>
</section>
