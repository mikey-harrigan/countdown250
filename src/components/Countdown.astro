---
---

<section class="bg-navy-dark py-12 border-y border-white/10">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-6">Time Until the Celebration</p>
    <div id="countdown" class="flex justify-center gap-2 sm:gap-8 md:gap-12">
      <div class="text-center">
        <div class="text-3xl sm:text-5xl md:text-6xl font-bold text-white font-heading" id="cd-days">---</div>
        <div class="text-white/40 text-[10px] sm:text-sm uppercase tracking-wider mt-1">Days</div>
      </div>
      <div class="text-gold/30 text-3xl sm:text-5xl md:text-6xl font-light">:</div>
      <div class="text-center">
        <div class="text-3xl sm:text-5xl md:text-6xl font-bold text-white font-heading" id="cd-hours">--</div>
        <div class="text-white/40 text-[10px] sm:text-sm uppercase tracking-wider mt-1">Hours</div>
      </div>
      <div class="text-gold/30 text-3xl sm:text-5xl md:text-6xl font-light">:</div>
      <div class="text-center">
        <div class="text-3xl sm:text-5xl md:text-6xl font-bold text-white font-heading" id="cd-mins">--</div>
        <div class="text-white/40 text-[10px] sm:text-sm uppercase tracking-wider mt-1">Minutes</div>
      </div>
      <div class="text-gold/30 text-3xl sm:text-5xl md:text-6xl font-light">:</div>
      <div class="text-center">
        <div class="text-3xl sm:text-5xl md:text-6xl font-bold text-white font-heading" id="cd-secs">--</div>
        <div class="text-white/40 text-[10px] sm:text-sm uppercase tracking-wider mt-1">Seconds</div>
      </div>
    </div>
  </div>
</section>

<script>
  const eventDate = new Date('2026-07-03T19:00:00-04:00').getTime();

  function updateCountdown() {
    const now = new Date().getTime();
    const diff = eventDate - now;

    if (diff <= 0) {
      document.getElementById('cd-days')!.textContent = '0';
      document.getElementById('cd-hours')!.textContent = '0';
      document.getElementById('cd-mins')!.textContent = '0';
      document.getElementById('cd-secs')!.textContent = '0';
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const secs = Math.floor((diff % (1000 * 60)) / 1000);

    document.getElementById('cd-days')!.textContent = String(days);
    document.getElementById('cd-hours')!.textContent = String(hours).padStart(2, '0');
    document.getElementById('cd-mins')!.textContent = String(mins).padStart(2, '0');
    document.getElementById('cd-secs')!.textContent = String(secs).padStart(2, '0');
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);
</script>
