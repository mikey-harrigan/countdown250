---
const ticketUrl = "https://www.eventbrite.com/e/the-official-countdown-250-ball-washington-dc-tickets-1982528927390?aff=websitemain";
---

<footer class="bg-navy-dark border-t border-white/10">
  <!-- CTA banner — navy contrasts cleanly with red urgency section above -->
  <div class="bg-navy py-12 text-center border-b border-white/10">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4 font-heading">Be There When History Is Made</h2>
      <p class="text-white/80 mb-4">
        Washington's premier America 250 celebration. Very limited availability.
      </p>
      <p class="text-white/70 text-sm mb-6">
        Proceeds help support <a href="https://www.operationrenewedhopefoundation.org" target="_blank" rel="noopener noreferrer" class="underline hover:text-white">Operation Renewed Hope Foundation</a> in their mission to house U.S. Veterans.
      </p>
      <button
        id="eb-footer-buy"
        class="eventbrite-checkout inline-block bg-red text-white px-10 py-4 text-lg font-semibold tracking-wider uppercase hover:bg-red-light transition-colors rounded shadow-lg cursor-pointer"
      >
        Get Tickets
      </button>
    </div>
  </div>

  <!-- Footer content -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid sm:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="logo-container relative h-24 w-48 mb-4">
          <img
            src="/images/logos/countdown250-navbar-logo.png"
            alt="All-American Countdown 250"
            class="relative h-full w-full object-contain"
          />
        </div>
        <p class="text-white/40 text-sm">
          Friday, July 3, 2026<br />
          Washington Hilton<br />
          Washington, D.C.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-white font-semibold text-sm tracking-wider uppercase mb-4">Quick Links</h3>
        <div class="space-y-2">
          <a href="/#about" class="block text-white/50 hover:text-white text-sm transition-colors">About the Event</a>
          <a href="/#experience" class="block text-white/50 hover:text-white text-sm transition-colors">Your Experience</a>
          <a href="/#venue" class="block text-white/50 hover:text-white text-sm transition-colors">The Venue</a>
          <a href="/#tickets" class="block text-white/50 hover:text-white text-sm transition-colors">Tickets</a>
          <a href="/updates/" class="block text-white/50 hover:text-white text-sm transition-colors">News & Updates</a>
          <button id="eb-footer-link" class="eventbrite-checkout block text-white/50 hover:text-white text-sm transition-colors cursor-pointer bg-transparent border-0 p-0 text-left">Get Tickets</button>
        </div>
      </div>

      <!-- Social / Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm tracking-wider uppercase mb-4">Connect</h3>
        <div class="space-y-2">
          <a href="https://www.facebook.com/profile.php?id=61577494264900" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-white/50 hover:text-white text-sm transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
            Facebook
          </a>
        </div>
      </div>
    </div>

    <!-- Disclaimer & Legal -->
    <div class="border-t border-white/10 mt-10 pt-8">
      <p class="text-white/30 text-xs mb-4 max-w-3xl">
        Tickets are non-refundable. Event is rain or shine. Date, time, entertainment, and programming are subject to change without notice. By purchasing a ticket, you consent to being photographed and filmed for promotional purposes. Dress code: Creative Patriotic Black Tie Optional. All ages welcome; minors must be accompanied by a responsible adult. No children's discounts.
      </p>
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <p class="text-white/30 text-xs">
          &copy; 2026 Merrifield Venture Partners, LLC d/b/a GoCity Group. All Rights Reserved.
        </p>
        <div class="flex gap-4">
          <a href="/faq/#terms" class="text-white/30 hover:text-white/50 text-xs transition-colors">Terms of Use</a>
          <a href="/faq/#terms" class="text-white/30 hover:text-white/50 text-xs transition-colors">Privacy Policy</a>
        </div>
      </div>
    </div>
  </div>
</footer>
