---

<section id="experience" class="py-20 sm:py-28 bg-navy text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-3">A Celebration for the Ages</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-6">Your All-Inclusive Experience</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-8"></div>
      <p class="text-white/70 text-lg max-w-3xl mx-auto">
        On July 3, the iconic Washington Hilton ballroom complex will transform into a breathtaking patriotic wonderland — an immersive celebration of American pride filled with extraordinary music, dazzling visuals, and memories that will last a lifetime!
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
      {features.map((f) => (
        <div class="bg-white/5 border border-white/10 rounded-xl px-5 py-4 hover:bg-white/10 transition-colors">
          <div class="flex items-center gap-3 mb-2">
            <div class="text-gold flex-shrink-0" set:html={icons[f.icon]} />
            <h3 class="text-base font-semibold text-white">{f.title}</h3>
          </div>
          <p class="text-white/60 text-sm pl-10">{f.desc}</p>
        </div>
      ))}
    </div>

    <!-- Photo strip -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="rounded-lg overflow-hidden aspect-square"><img src="/countdown250/images/event/diverse-grand-ballroom.png" alt="Diverse guests celebrating in a grand patriotic ballroom" class="object-cover w-full h-full scale-[1.02]" /></div>
      <div class="rounded-lg overflow-hidden aspect-square"><img src="/countdown250/images/event/diverse-live-band.png" alt="Live band performing for a diverse crowd" class="object-cover w-full h-full scale-[1.02]" /></div>
      <div class="rounded-lg overflow-hidden aspect-square"><img src="/countdown250/images/event/diverse-immersive.png" alt="Guests enjoying immersive patriotic experiences" class="object-cover w-full h-full scale-[1.02]" /></div>
      <div class="rounded-lg overflow-hidden aspect-square"><img src="/countdown250/images/event/diverse-premium-bar.png" alt="Premium open bar with diverse guests enjoying cocktails" class="object-cover w-full h-full scale-[1.02]" /></div>
    </div>

    <!-- Ticket options callout -->
    <div class="text-center mt-12 bg-white/5 border border-white/10 rounded-2xl p-8 max-w-2xl mx-auto">
      <p class="text-white text-lg mb-4">
        With 5 ticket options, there is something for everyone.
      </p>
      <a
        href="#tickets"
        class="inline-block bg-red hover:bg-red-light text-white px-10 py-4 text-lg font-semibold tracking-wider uppercase transition-all rounded shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        View Ticket Options
      </a>
    </div>
  </div>
</section>
