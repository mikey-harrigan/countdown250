---
const ticketUrl = "https://www.eventbrite.com/e/all-american-countdown-250-ball-tickets-1982528927390";

const features = [
  { icon: "party", title: "6 Party Zones", desc: "Each with its own vibe, music, and atmosphere" },
  { icon: "music", title: "4 Stages & Dance Floors", desc: "Star-studded lineup of diverse bands and DJs" },
  { icon: "drink", title: "Premium Open Bars", desc: "Artisanal cocktails and top-shelf selections all night" },
  { icon: "food", title: "Culinary Stations", desc: "Exquisite food prepared by premier chefs" },
  { icon: "star", title: "Hero Awards", desc: "All-American Hero Lifetime Achievement Awards ceremony" },
  { icon: "sparkle", title: "Midnight Countdown", desc: "An iconic New Year's Eve-style countdown to July 4th" },
  { icon: "camera", title: "Immersive Experiences", desc: "Roaming entertainers, interactive attractions, and more" },
  { icon: "broadcast", title: "Live Webcast", desc: "Be part of a nationally broadcast celebration" },
];

