    <style>
      @keyframes scroll-strip {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .animate-scroll-strip {
        animation: scroll-strip 80s linear infinite;
      }
      .animate-scroll-strip:hover {
        animation-play-state: paused;
      }
    </style>

    <!-- Ticket options callout -->
    <div class="text-center mt-12 bg-white/5 border border-white/10 rounded-2xl p-8 max-w-2xl mx-auto">
      <p class="text-white text-lg mb-4">
        Three distinct experiences. One unforgettable evening.
      </p>
      <a
        href="#tickets"
        class="inline-block bg-red hover:bg-red-light text-white px-10 py-4 text-lg font-semibold tracking-wider uppercase transition-all rounded shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        Reserve Your Place
      </a>
    </div>
  </div>
</section>
