---

<section id="experience" class="py-20 sm:py-28 bg-navy text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-3">A Celebration for the Ages</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-6">Your All-Inclusive Experience</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-8"></div>
      <p class="text-white/70 text-lg max-w-3xl mx-auto">
        On July 3, the iconic Washington Hilton ballroom complex will transform into a an extraordinary celebration of American heritage — an evening of world-class entertainment, refined elegance, and memories that will last a lifetime.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
      {features.map((f) => (
        <div class="bg-white/5 border border-white/10 rounded-xl px-5 py-4 hover:bg-white/10 transition-colors">
          <div class="flex items-center gap-3 mb-2">
            <div class="text-gold flex-shrink-0" set:html={icons[f.icon]} />
            <h3 class="text-base font-semibold text-white">{f.title}</h3>
          </div>
          <p class="text-white/60 text-sm pl-10">{f.desc}</p>
        </div>
      ))}
    </div>

    <!-- Scrolling Photo Strip — real inaugural ball photos mixed with event imagery -->
    <div class="overflow-hidden relative">
      <div class="flex gap-3 animate-scroll-strip">
        <!-- First set (20 images — alternating real/AI) -->
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/formal-dinner-table.png" alt="Elegant formal dinner under crystal chandeliers" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-drumline.jpg" alt="Drumline performing on stage" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/red-carpet-arrival.png" alt="Guests arriving on the red carpet in black tie" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-awards-ceremony.jpg" alt="Awards ceremony with presidential seal and American flag" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/patriotic-stage-orchestra.png" alt="Grand stage with orchestra and American flags" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-sax-player.jpg" alt="Saxophonist performing in black tie" class="object-cover w-full h-full" loading="lazy" /></div>
        <!-- Flag banner: 6 Ballrooms, 4 Stages, Bands & DJs -->
        <div class="flex-shrink-0 w-80 md:w-96 rounded-lg overflow-hidden aspect-[3/2]"><img src="/images/event/countdown250-flag-ballrooms.png" alt="Countdown 250 — 6 Ballrooms, 4 Stages, Bands and DJs" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/patriotic-cocktails-bar.png" alt="Premium cocktails at an elegant patriotic bar" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-stage-usa.jpg" alt="Performers on stage with USA display" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/guests-cocktail-mingling.png" alt="Guests mingling over cocktails" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-country-band.jpg" alt="Country band performing live" class="object-cover w-full h-full" loading="lazy" /></div>
        <!-- Flag banner: All-Inclusive, Black-Tie Optional, VIP Service -->
        <div class="flex-shrink-0 w-80 md:w-96 rounded-lg overflow-hidden aspect-[3/2]"><img src="/images/event/countdown250-flag-inclusive.png" alt="Countdown 250 — All-Inclusive, Black-Tie Optional, VIP Service" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/dj-dance-floor.png" alt="DJ and guests on the dance floor" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-glamorous-couple.jpg" alt="Glamorous couple at the ball" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/hero-awards-ceremony.png" alt="Hero awards ceremony on stage" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-family-formal.jpg" alt="Family dressed up at the celebration" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/statesman-vip-dinner.png" alt="Intimate VIP dinner experience" class="object-cover w-full h-full" loading="lazy" /></div>
        <!-- Flag banner: Midnight Countdown, Premium Open Bar, Fine Cuisine -->
        <div class="flex-shrink-0 w-80 md:w-96 rounded-lg overflow-hidden aspect-[3/2]"><img src="/images/event/countdown250-flag-midnight.png" alt="Countdown 250 — Midnight Countdown, Premium Open Bar, Fine Cuisine" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-family-chandeliers.jpg" alt="Guests under grand ballroom chandeliers" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/ballroom-stage.jpg" alt="Grand ballroom stage performance" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/color-guard.jpg" alt="Military color guard ceremony" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/formal-dinner.jpg" alt="Guests enjoying formal dinner" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/hilton-exterior-twilight.jpg" alt="Washington Hilton at twilight" class="object-cover w-full h-full" loading="lazy" /></div>
        <!-- Duplicate set for seamless loop -->
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/formal-dinner-table.png" alt="Elegant formal dinner under crystal chandeliers" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-drumline.jpg" alt="Drumline performing on stage" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/red-carpet-arrival.png" alt="Guests arriving on the red carpet in black tie" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-awards-ceremony.jpg" alt="Awards ceremony with presidential seal and American flag" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/patriotic-stage-orchestra.png" alt="Grand stage with orchestra and American flags" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-sax-player.jpg" alt="Saxophonist performing in black tie" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-80 md:w-96 rounded-lg overflow-hidden aspect-[3/2]"><img src="/images/event/countdown250-flag-ballrooms.png" alt="Countdown 250 — 6 Ballrooms, 4 Stages, Bands and DJs" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/patriotic-cocktails-bar.png" alt="Premium cocktails at an elegant patriotic bar" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-stage-usa.jpg" alt="Performers on stage with USA display" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/guests-cocktail-mingling.png" alt="Guests mingling over cocktails" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-country-band.jpg" alt="Country band performing live" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-80 md:w-96 rounded-lg overflow-hidden aspect-[3/2]"><img src="/images/event/countdown250-flag-inclusive.png" alt="Countdown 250 — All-Inclusive, Black-Tie Optional, VIP Service" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/dj-dance-floor.png" alt="DJ and guests on the dance floor" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-glamorous-couple.jpg" alt="Glamorous couple at the ball" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/hero-awards-ceremony.png" alt="Hero awards ceremony on stage" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-family-formal.jpg" alt="Family dressed up at the celebration" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/statesman-vip-dinner.png" alt="Intimate VIP dinner experience" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-80 md:w-96 rounded-lg overflow-hidden aspect-[3/2]"><img src="/images/event/countdown250-flag-midnight.png" alt="Countdown 250 — Midnight Countdown, Premium Open Bar, Fine Cuisine" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/inaugural-family-chandeliers.jpg" alt="Guests under grand ballroom chandeliers" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/ballroom-stage.jpg" alt="Grand ballroom stage performance" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/color-guard.jpg" alt="Military color guard ceremony" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/formal-dinner.jpg" alt="Guests enjoying formal dinner" class="object-cover w-full h-full" loading="lazy" /></div>
        <div class="flex-shrink-0 w-56 md:w-72 rounded-lg overflow-hidden aspect-square"><img src="/images/event/hilton-exterior-twilight.jpg" alt="Washington Hilton at twilight" class="object-cover w-full h-full" loading="lazy" /></div>
