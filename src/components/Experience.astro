---

<section id="experience" class="py-20 sm:py-28 bg-navy text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-3">A Celebration for the Ages</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-6">Your All-Inclusive Experience</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-8"></div>
      <p class="text-white/70 text-lg max-w-3xl mx-auto">
        The iconic Washington Hilton ballroom complex will be transformed into a magnificent patriotic wonderland — an immersive celebration of American pride filled with extraordinary music, dazzling visuals, and memories that will last a lifetime.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
      {features.map((f) => (
        <div class="bg-white/5 border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-colors">
          <div class="text-gold mb-4" set:html={icons[f.icon]} />
          <h3 class="text-lg font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-white/60 text-sm">{f.desc}</p>
        </div>
      ))}
    </div>

    <!-- Photo strip -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <img src="/countdown250/images/event-photos/aab-2025-statue-liberty-celebration.jpg" alt="Patriotic celebration with Statue of Liberty backdrop" class="rounded-lg object-cover w-full aspect-square" />
      <img src="/countdown250/images/event-photos/aab-2025-usa-letters-stage.jpg" alt="Illuminated USA letters and full stage setup" class="rounded-lg object-cover w-full aspect-square" />
      <img src="/countdown250/images/event-photos/aab-2025-emcee-triumph.jpg" alt="Emcee celebrating on stage" class="rounded-lg object-cover w-full aspect-square" />
      <img src="/countdown250/images/event-photos/aab-2025-elegant-gown.jpg" alt="Elegant guest in stunning gown" class="rounded-lg object-cover w-full aspect-square" />
    </div>

    <!-- Ticket options callout -->
    <div class="text-center mt-12 bg-white/5 border border-white/10 rounded-2xl p-8 max-w-2xl mx-auto">
      <p class="text-white text-lg mb-4">
        With 5 ticket options, there is something for everyone.
      </p>
      <a
        href="#tickets"
        class="inline-block bg-red hover:bg-red-light text-white px-10 py-4 text-lg font-semibold tracking-wider uppercase transition-all rounded shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        View Ticket Options
      </a>
    </div>
  </div>
</section>
