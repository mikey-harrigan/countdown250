---
import '../styles/global.css';
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  heading: string;
  subheading?: string;
}

const { title, description, heading, subheading } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Navbar />
  <main>
    <!-- Hero header for subpages -->
    <section class="relative pt-32 pb-20 bg-navy text-white overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-navy-dark/90 to-navy"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-4">{subheading || "All-American Countdown 250 Ball"}</p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-4 font-heading">{heading}</h1>
        <div class="w-20 h-1 bg-red mx-auto"></div>
      </div>
    </section>

    <!-- Coming Soon content -->
    <section class="py-28 sm:py-36 bg-white">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <div class="mb-8">
          <svg class="w-16 h-16 text-gold mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h2 class="text-2xl sm:text-3xl font-bold text-navy mb-4 font-heading">Coming Soon</h2>
        <p class="text-slate/60 text-lg mb-8">
          This page is under construction. Check back soon for updates.
        </p>
        <a
          href="/"
          class="inline-block bg-red hover:bg-red-light text-white px-8 py-3 text-sm font-semibold tracking-wider uppercase transition-all rounded shadow-lg hover:-translate-y-0.5"
        >
          Back to Home
        </a>
      </div>
    </section>

    <slot />
  </main>
  <Footer />
</BaseLayout>
