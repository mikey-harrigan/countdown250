---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const ticketUrl = "https://www.eventbrite.com/e/the-official-countdown-250-ball-washington-dc-tickets-1982528927390?aff=websitemain";

const quickBenefits = [
  "Priority entry with personal concierge service throughout the night",
  "Upgraded culinary and premium beverage experience all evening",
  "Access to exclusive entertainment areas and elevated experiences",
  "Private tour of historic spaces reserved for presidents and dignitaries",
  "Premium limited-edition official event gift",
  "Recognition in the official program and personal stage acknowledgments",
  "Option to host your Party Inside the Party",
];

const fullBenefits = [
  {
    title: "Arrival & Access",
    items: [
      "Priority entry",
      "Personal concierge service throughout the evening",
    ],
  },
  {
    title: "Food & Beverage — All Evening",
    items: [
      "Premium bars",
      "Elevated dining",
    ],
  },
  {
    title: "Exclusive Access",
    items: [
      "Private historic areas",
      "Special entertainment zones",
      "Exclusive entertainers and attractions",
    ],
  },
  {
    title: "Recognition & Gifts",
    items: [
      "Official program inclusion",
      "Personal stage announcement",
      "Premium signature gift and souvenirs",
    ],
  },
  {
    title: "Hosting Options",
    items: [
      "Hosted Groups available",
      "Option to host your Party Inside the Party",
    ],
  },
  {
    title: "Surprise Enhancements",
    items: [
      "Additional premium touches throughout the evening",
    ],
  },
];

const hostBenefits = [
  "Reserved premium gathering place for your group",
  "Guests purchase their own qualifying tickets",
  "Personalized table signage featuring the Host's name and group name",
  "Personal recognition as a Host in the official event program",
  "Personal recognition as a Host on the event website",
  "Public \"Toast to the Hosts\" ceremony during the event",
  "Fast and easy group hosting — we handle the details",
  "No additional cost to be a Host",
];

const guestBenefits = [
  "Reserved premium gathering place with the group",
  "Easy to join your group after purchase",
  "Included in the \"Party Inside the Party\" experience",
  "No additional cost beyond their qualifying ticket",
  "Shared memories to last a lifetime with your invited group",
];

const faqs = [
  {
    q: "Is the Statesman's Concierge Pass a ticket option?",
    a: "Yes. The Statesman's Concierge Pass is Countdown 250's premier ticket option for guests seeking the most elevated experience.",
  },
  {
    q: "Do I need to be part of a Hosted Group?",
    a: "No. Hosted Groups are optional. Guests who are not part of a Hosted Group will still enjoy the full Statesman's Concierge Pass experience.",
  },
  {
    q: "Do Hosts have to buy tickets for their guests?",
    a: "No. Hosts invite their guests, and guests purchase their own qualifying Statesman's Concierge Passes.",
  },
  {
    q: "Does it cost extra to be a Host?",
    a: "No. There is no additional cost to be a Host beyond the required qualifying Statesman's Concierge Passes.",
  },
  {
    q: "How do I start or join a Hosted Group?",
    a: "After purchasing Statesman's Concierge Passes, guests will receive simple follow-up instructions explaining how to start a Hosted Group or join an existing one.",
  },
  {
    q: "If I buy multiple Statesman's Concierge Passes in one order, will we sit together?",
    a: "Yes. Guests purchasing multiple tickets in the same order will be seated together.",
  },
  {
    q: "What recognition do Hosts receive?",
    a: "Hosts may receive personalized table signage, personal recognition as a Host in the official event program, personal recognition on the event website, and recognition during the public \"Toast to the Hosts\" ceremony.",
  },
  {
    q: "Can groups of all sizes participate?",
    a: "Yes. Groups of all sizes are welcome. Larger qualifying groups may receive additional Hosted Group recognition and seating coordination.",
  },
];
---

<BaseLayout
  title="Statesman's Concierge Pass & Hosted Groups | Countdown 250 Ball"
  description="Learn about the Statesman's Concierge Pass, Countdown 250's premier ticket option, including concierge service, premium amenities, exclusive access, and Hosted Groups."
  ogImage="/images/event/statesman-vip-dinner.png"
>
  <Navbar />

  <!-- ============================================================ -->
  <!-- SECTION 1: HERO -->
  <!-- ============================================================ -->
  <section class="relative pt-32 pb-20 sm:pb-24 bg-gradient-to-b from-navy-dark via-navy to-navy-dark text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, rgba(197,164,78,0.4) 0%, transparent 70%);"></div>
    </div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/50 to-transparent"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-gold font-medium tracking-[0.3em] uppercase text-xs sm:text-sm mb-5">Countdown 250 Premium Experience</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold mb-3 font-heading">Statesman&rsquo;s Concierge Pass</h1>
      <p class="text-xl sm:text-2xl text-gold/90 italic font-light mb-8">Our Premier Ticket Option</p>
      <div class="w-24 h-0.5 bg-gold mx-auto mb-10"></div>

      <p class="text-lg sm:text-xl text-white/90 leading-relaxed max-w-3xl mx-auto mb-10">
        For guests seeking one of the most extraordinary evenings of their lives, the Statesman&rsquo;s Concierge Pass offers the most elevated Countdown 250 experience &mdash; personal concierge service, premium food and beverage, exclusive access areas, recognition opportunities, signature gifts, and the option to host your own Party Inside the Party.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href={ticketUrl}
          class="eventbrite-checkout inline-flex items-center justify-center gap-2 bg-gold text-navy-dark hover:bg-gold/90 px-9 py-4 text-sm font-bold tracking-[0.12em] uppercase transition-all rounded ring-1 ring-gold/30 ring-offset-2 ring-offset-navy shadow-xl hover:shadow-2xl hover:-translate-y-0.5"
        >
          <span class="text-navy-dark">&#9733;</span>
          <span>Secure Statesman&rsquo;s Concierge Passes</span>
        </a>
        <a
          href="#hosted-groups"
          class="border-2 border-gold/60 text-gold hover:bg-gold/10 px-9 py-4 text-sm font-semibold tracking-[0.2em] uppercase transition-all rounded"
        >
          View Hosted Group Details
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 2: QUICK BENEFITS -->
  <!-- ============================================================ -->
  <section class="py-20 sm:py-24 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-6 font-heading text-center leading-tight">What&rsquo;s Included</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-12"></div>

      <ul class="space-y-4">
        {quickBenefits.map((b) => (
          <li class="flex items-start bg-white rounded-lg shadow-sm border-l-4 border-gold px-5 py-4">
            <svg class="w-6 h-6 text-gold flex-shrink-0 mt-0.5 mr-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
            </svg>
            <span class="text-slate text-base sm:text-lg leading-relaxed">{b}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 3: FULL BENEFITS (ACCORDIONS) -->
  <!-- ============================================================ -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-6 font-heading text-center leading-tight">Full Statesman&rsquo;s Concierge Pass Benefits</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-12"></div>

      <div class="space-y-3">
        {fullBenefits.map(({ title, items }) => (
          <details class="group bg-cream rounded-xl border border-navy/10 overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none hover:bg-cream/70 transition-colors">
              <h3 class="text-lg sm:text-xl font-bold text-navy font-heading">{title}</h3>
              <svg class="w-5 h-5 flex-shrink-0 text-gold transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 pt-1">
              <ul class="space-y-2 text-slate/85 text-base leading-relaxed">
                {items.map((item) => (
                  <li class="flex items-start">
                    <span class="text-gold mr-3 mt-1.5 flex-shrink-0 text-[8px]">&#9679;</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 4: HOSTED GROUPS -->
  <!-- ============================================================ -->
  <section id="hosted-groups" class="relative py-20 sm:py-28 bg-gradient-to-b from-navy via-navy-dark to-navy text-white overflow-hidden scroll-mt-24">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-gold font-semibold tracking-[0.3em] uppercase text-xs sm:text-sm mb-5">Party Inside the Party</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 font-heading leading-tight">Everything You Need to Know About Hosting or Joining a Party Inside the Party</h2>
      <p class="text-lg sm:text-xl md:text-2xl text-gold/90 italic font-light mb-8 max-w-3xl mx-auto leading-snug">Start or join a Hosted Group in about 15 seconds. We take it from there.</p>
      <div class="w-24 h-0.5 bg-gold mx-auto mb-10"></div>

      <div class="space-y-5 text-lg text-white/90 leading-relaxed text-left max-w-3xl mx-auto">
        <p>
          Hosted Groups are a free optional benefit for Statesman&rsquo;s Concierge Pass guests. After purchasing Statesman&rsquo;s Concierge Passes, guests will receive simple follow-up instructions explaining how to start their own Hosted Group or join an existing one.
        </p>
        <p class="text-white">
          <strong class="font-semibold">Hosts invite their guests. Guests purchase their own qualifying Statesman&rsquo;s Concierge Passes. We handle the details.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 5: HOW IT WORKS -->
  <!-- ============================================================ -->
  <section class="py-20 sm:py-24 bg-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-6 font-heading text-center leading-tight">How Hosted Groups Work</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-12 sm:mb-14"></div>

      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
        <div class="bg-white rounded-xl border-l-4 border-gold p-6 sm:p-7 shadow-sm">
          <div class="text-gold font-bold text-3xl mb-3 font-heading">1</div>
          <h3 class="text-lg sm:text-xl font-bold text-navy mb-2 font-heading leading-tight">Secure Statesman&rsquo;s Concierge Passes</h3>
          <p class="text-slate/80 leading-relaxed">Purchase your Statesman&rsquo;s Concierge Passes first.</p>
        </div>
        <div class="bg-white rounded-xl border-l-4 border-gold p-6 sm:p-7 shadow-sm">
          <div class="text-gold font-bold text-3xl mb-3 font-heading">2</div>
          <h3 class="text-lg sm:text-xl font-bold text-navy mb-2 font-heading leading-tight">Start or Join a Hosted Group</h3>
          <p class="text-slate/80 leading-relaxed">After purchase, follow the simple instructions we send to start your own Hosted Group or join an existing one.</p>
        </div>
        <div class="bg-white rounded-xl border-l-4 border-gold p-6 sm:p-7 shadow-sm">
          <div class="text-gold font-bold text-3xl mb-3 font-heading">3</div>
          <h3 class="text-lg sm:text-xl font-bold text-navy mb-2 font-heading leading-tight">We Handle the Details</h3>
          <p class="text-slate/80 leading-relaxed">We coordinate the details, help track your group, and arrange the Hosted Group experience.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 6: TWO BENEFITS BOXES -->
  <!-- ============================================================ -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-6 font-heading text-center leading-tight">Why Hosted Groups Work So Well</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-12 sm:mb-14"></div>

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        <!-- BOX 1: Benefits to Hosts -->
        <div class="relative bg-gradient-to-br from-navy-dark via-navy to-navy-dark text-white rounded-xl p-7 sm:p-8 md:p-10 shadow-xl overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/70 to-transparent"></div>
          <p class="text-gold font-bold tracking-[0.3em] uppercase text-xs sm:text-sm mb-6">Benefits to Hosts</p>
          <ul class="space-y-3 text-white/90 text-[15px] sm:text-base leading-snug">
            {hostBenefits.map((b) => (
              <li class="flex items-start">
                <span class="text-gold mr-3 flex-shrink-0 mt-1 text-sm">&#10022;</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- BOX 2: Why Guests Love It -->
        <div class="bg-cream rounded-xl p-7 sm:p-8 md:p-10 border border-navy/10">
          <p class="text-navy/80 font-bold tracking-[0.3em] uppercase text-xs sm:text-sm mb-6">Why Guests Love It</p>
          <ul class="space-y-3 text-slate text-[15px] sm:text-base leading-snug">
            {guestBenefits.map((b) => (
              <li class="flex items-start">
                <span class="text-navy/40 mr-2.5 font-bold flex-shrink-0 mt-1">&bull;</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 7: SEATING NOTE -->
  <!-- ============================================================ -->
  <section class="py-16 sm:py-20 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-navy mb-6 font-heading leading-tight">A Simple Seating Note</h2>
      <div class="w-16 h-1 bg-red mx-auto mb-8"></div>
      <p class="text-lg text-slate leading-relaxed">
        Guests purchasing multiple tickets in the same order will be seated together. Guests not part of a Hosted Group will still enjoy the full Statesman&rsquo;s Concierge Pass experience and be seated in premium shared seating areas with other independent guests and notable attendees.
      </p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 8: FAQ ACCORDIONS -->
  <!-- ============================================================ -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-6 font-heading text-center leading-tight">Statesman&rsquo;s Concierge Pass &amp; Hosted Group FAQs</h2>
      <div class="w-20 h-1 bg-red mx-auto mb-12"></div>

      <div class="space-y-3">
        {faqs.map(({ q, a }) => (
          <details class="group bg-cream rounded-xl border border-navy/10 overflow-hidden">
            <summary class="flex items-start justify-between gap-4 px-6 py-5 cursor-pointer list-none hover:bg-cream/70 transition-colors">
              <h3 class="text-base sm:text-lg font-bold text-navy font-heading leading-snug">{q}</h3>
              <svg class="w-5 h-5 flex-shrink-0 text-gold mt-1 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 pt-1">
              <p class="text-slate/80 leading-relaxed">{a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 9: FINAL CTA -->
  <!-- ============================================================ -->
  <section class="py-20 sm:py-24 bg-red text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6 font-heading leading-tight">Make It the Night of Their Lives</h2>
      <div class="w-24 h-0.5 bg-white/60 mx-auto mb-8"></div>

      <p class="text-lg text-white/95 leading-relaxed mb-10">
        Whether you are celebrating with a spouse, friends, family, clients, alumni, colleagues, or a group of proud Americans, the Statesman&rsquo;s Concierge Pass and Hosted Groups program make it easy to create a once-in-a-lifetime Countdown 250 experience.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href={ticketUrl}
          class="eventbrite-checkout inline-block bg-white text-red px-10 py-4 text-sm font-bold tracking-[0.2em] uppercase hover:bg-cream transition-colors rounded shadow-lg hover:-translate-y-0.5"
        >
          Secure Statesman&rsquo;s Concierge Passes
        </a>
        <a
          href="/homepage-preview/#tickets"
          class="border-2 border-white text-white px-10 py-4 text-sm font-semibold tracking-[0.2em] uppercase hover:bg-white hover:text-red transition-colors rounded"
        >
          Return to Ticket Options
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* Remove default details/summary marker */
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
