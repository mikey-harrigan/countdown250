---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const ticketUrl = "https://www.eventbrite.com/e/the-official-countdown-250-ball-washington-dc-tickets-1982528927390?aff=websitemain";

// Statesman section: collapsed accordions
const statesmanDetails = [
  { title: "Arrival & Access", items: ["Priority entry", "Personal concierge throughout the evening", "VIP arrival treatment"] },
  { title: "Food & Beverage", items: ["Premium bars all evening", "Elevated dining", "Refined hospitality from start to finish"] },
  { title: "Exclusive Access & Recognition", items: ["Private historic spaces", "Premium gathering areas", "Official program recognition", "Signature keepsake gift"] },
  { title: "Hosted Group Privileges", items: ["Host your own Party Inside the Party", "Group gathering privileges", "No additional hosting fee"] },
];

// Hosted Table benefits — two columns
const hostBenefits = [
  "Reserved premium gathering place",
  "Guests purchase their own qualifying passes",
  "Personalized signage",
  "Recognition opportunities",
  "Public Toast to the Hosts",
  "No additional hosting cost",
];

const guestBenefits = [
  "Easy to join",
  "Celebrate together",
  "Premium shared atmosphere",
  "No added cost",
  "Lifetime memories",
];

// FAQ
const faqs = [
  { q: "Is this a ticket option?", a: "Yes. The Statesman's Concierge Pass is Countdown 250's premier ticket option." },
  { q: "Do I need a Hosted Group?", a: "No. Hosted Groups are entirely optional. Every guest enjoys the full Statesman's experience either way." },
  { q: "Do Hosts pay for guests?", a: "No. Hosts invite their guests; guests purchase their own qualifying passes." },
  { q: "Does it cost extra to Host?", a: "No. Hosting is included with the Statesman's Concierge Pass at no additional cost." },
  { q: "How do I start a group?", a: "After purchase, you'll receive simple follow-up instructions for starting your own Hosted Group or joining an existing one." },
  { q: "If I buy multiple passes, do we sit together?", a: "Yes. Guests in the same order are seated together." },
  { q: "Can small groups participate?", a: "Yes. Groups of all sizes are welcome." },
];
---

<BaseLayout
  title="Statesman's Concierge Pass | Countdown 250 Ball"
  description="Countdown 250's premier experience. Concierge service, exclusive access, refined hospitality, and the option to host your own Party Inside the Party."
  ogImage="/images/event/statesman-vip-dinner.png"
>
  <Navbar />

  <!-- ============================================================ -->
  <!-- 1. HERO — ballroom spotlights, exclusive invitation tone -->
  <!-- ============================================================ -->
  <section class="relative pt-40 pb-32 sm:pt-48 sm:pb-40 bg-gradient-to-b from-[#0B1F3A] via-[#163A70] to-[#0B1F3A] text-white overflow-hidden">
    <!-- Multi-spot ballroom lighting -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-32 left-[12%] w-[42rem] h-[42rem] rounded-full opacity-[0.16]" style="background: radial-gradient(circle, rgba(197,164,78,1) 0%, transparent 60%); filter: blur(50px);"></div>
      <div class="absolute -bottom-40 right-[10%] w-[40rem] h-[40rem] rounded-full opacity-[0.13]" style="background: radial-gradient(circle, rgba(197,164,78,1) 0%, transparent 60%); filter: blur(60px);"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[24rem] h-[24rem] rounded-full opacity-[0.07]" style="background: radial-gradient(circle, rgba(197,164,78,1) 0%, transparent 70%); filter: blur(40px);"></div>
    </div>
    <!-- Hairline gold edges -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#C5A44E]/45 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#C5A44E]/45 to-transparent"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p class="text-[#C5A44E]/85 font-medium tracking-[0.4em] uppercase text-[11px] sm:text-xs mb-10">By Invitation</p>

      <h1 class="font-heading font-bold text-4xl sm:text-5xl md:text-6xl leading-[1.1] mb-10">
        The Statesman&rsquo;s<br /> Concierge Pass
      </h1>

      <!-- Gold ornament divider -->
      <div class="flex items-center justify-center gap-4 mb-10">
        <div class="w-14 h-px bg-[#C5A44E]/60"></div>
        <div class="w-1.5 h-1.5 bg-[#C5A44E] rotate-45"></div>
        <div class="w-14 h-px bg-[#C5A44E]/60"></div>
      </div>

      <p class="text-white/85 text-lg sm:text-xl font-light leading-relaxed max-w-xl mx-auto mb-14">
        An evening curated for those who expect the extraordinary &mdash; and a stage on which to celebrate it with the people who matter most.
      </p>

      <a
        href={ticketUrl}
        class="eventbrite-checkout inline-block bg-[#C5A44E] text-[#0B1F3A] hover:bg-[#C5A44E]/90 px-10 py-4 text-[13px] font-semibold tracking-[0.2em] uppercase transition-all rounded-sm shadow-xl hover:-translate-y-0.5"
      >
        Reserve Your Pass
      </a>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 2. TWO NAVIGATION CARDS — the only menu the page needs -->
  <!-- ============================================================ -->
  <section class="relative py-24 sm:py-32 bg-[#F7F3E8]">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14 sm:mb-16">
        <p class="text-[#C5A44E] font-medium tracking-[0.4em] uppercase text-[11px] mb-4">Begin Where You Wish</p>
        <h2 class="font-heading text-2xl sm:text-3xl text-[#0B1F3A] font-bold leading-tight">Two Questions, One Experience</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        <!-- Card 1: Statesman -->
        <a
          href="#statesman"
          class="group relative block bg-gradient-to-br from-[#0B1F3A] via-[#163A70] to-[#0B1F3A] rounded-md overflow-hidden border border-[#C5A44E]/30 hover:border-[#C5A44E] transition-all p-10 sm:p-12 text-center hover:-translate-y-1 shadow-xl hover:shadow-2xl"
        >
          <!-- Soft inner spotlight -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[20rem] h-[20rem] rounded-full opacity-[0.10] pointer-events-none" style="background: radial-gradient(circle, rgba(197,164,78,1) 0%, transparent 60%); filter: blur(40px);"></div>
          <div class="relative z-10">
            <p class="text-[#C5A44E]/85 font-medium tracking-[0.4em] uppercase text-[10px] mb-6">No. 01</p>
            <h3 class="font-heading text-xl sm:text-2xl text-white font-medium leading-snug mb-5">
              What Is the Statesman&rsquo;s<br class="hidden sm:block" /> Concierge Pass?
            </h3>
            <div class="w-10 h-px bg-[#C5A44E]/60 mx-auto mb-5"></div>
            <p class="text-white/75 text-[15px] sm:text-base leading-relaxed mb-7 max-w-xs mx-auto">
              Concierge service. Private access. Refined hospitality.
            </p>
            <span class="inline-flex items-center gap-2 text-[#C5A44E] text-xs font-semibold tracking-[0.25em] uppercase group-hover:gap-3 transition-all">
              Discover
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>

        <!-- Card 2: Hosted Tables -->
        <a
          href="#hosted-tables"
          class="group relative block bg-gradient-to-br from-[#0B1F3A] via-[#163A70] to-[#0B1F3A] rounded-md overflow-hidden border border-[#C5A44E]/30 hover:border-[#C5A44E] transition-all p-10 sm:p-12 text-center hover:-translate-y-1 shadow-xl hover:shadow-2xl"
        >
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[20rem] h-[20rem] rounded-full opacity-[0.10] pointer-events-none" style="background: radial-gradient(circle, rgba(197,164,78,1) 0%, transparent 60%); filter: blur(40px);"></div>
          <div class="relative z-10">
            <p class="text-[#C5A44E]/85 font-medium tracking-[0.4em] uppercase text-[10px] mb-6">No. 02</p>
            <h3 class="font-heading text-xl sm:text-2xl text-white font-medium leading-snug mb-5">
              What Is the Hosted Table /<br class="hidden sm:block" /> Party Inside the Party Program?
            </h3>
            <div class="w-10 h-px bg-[#C5A44E]/60 mx-auto mb-5"></div>
            <p class="text-white/75 text-[15px] sm:text-base leading-relaxed mb-7 max-w-xs mx-auto">
              Your guests. Your table. Your unforgettable evening together.
            </p>
            <span class="inline-flex items-center gap-2 text-[#C5A44E] text-xs font-semibold tracking-[0.25em] uppercase group-hover:gap-3 transition-all">
              Discover
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 3. STATESMAN — second navy moment, ballroom continues -->
  <!-- ============================================================ -->
  <section id="statesman" class="relative py-28 sm:py-36 bg-gradient-to-b from-[#0B1F3A] via-[#163A70] to-[#0B1F3A] text-white overflow-hidden scroll-mt-24">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-[15%] w-[36rem] h-[36rem] rounded-full opacity-[0.12]" style="background: radial-gradient(circle, rgba(197,164,78,1) 0%, transparent 60%); filter: blur(50px);"></div>
      <div class="absolute bottom-0 right-[15%] w-[32rem] h-[32rem] rounded-full opacity-[0.10]" style="background: radial-gradient(circle, rgba(197,164,78,1) 0%, transparent 60%); filter: blur(50px);"></div>
    </div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#C5A44E]/40 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#C5A44E]/40 to-transparent"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#C5A44E]/85 font-medium tracking-[0.4em] uppercase text-[11px] mb-5">No. 01</p>
        <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold leading-tight mb-8">
          What Is the Statesman&rsquo;s<br /> Concierge Pass?
        </h2>

        <div class="flex items-center justify-center gap-4 mb-10">
          <div class="w-12 h-px bg-[#C5A44E]/60"></div>
          <div class="w-1.5 h-1.5 bg-[#C5A44E] rotate-45"></div>
          <div class="w-12 h-px bg-[#C5A44E]/60"></div>
        </div>

        <p class="text-white/85 text-lg leading-relaxed max-w-xl mx-auto mb-4">
          The most elevated Countdown 250 experience &mdash; created for guests who expect the very best.
        </p>
        <p class="text-white/65 text-base leading-relaxed max-w-xl mx-auto">
          Ideal for couples, executives, hosts, clients, alumni groups, and discerning guests.
        </p>
      </div>

      <!-- 4 elegant icon callouts -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 sm:gap-10 mb-16 sm:mb-20 pt-10 border-t border-[#C5A44E]/20">
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 mb-3 text-[#C5A44E]">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.25">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </div>
          <p class="text-white/90 text-xs sm:text-sm font-medium leading-snug tracking-wide">Personal Concierge</p>
        </div>
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 mb-3 text-[#C5A44E]">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.25">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
            </svg>
          </div>
          <p class="text-white/90 text-xs sm:text-sm font-medium leading-snug tracking-wide">Premium F&amp;B</p>
        </div>
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 mb-3 text-[#C5A44E]">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.25">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
            </svg>
          </div>
          <p class="text-white/90 text-xs sm:text-sm font-medium leading-snug tracking-wide">Exclusive Access</p>
        </div>
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 mb-3 text-[#C5A44E]">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.25">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <p class="text-white/90 text-xs sm:text-sm font-medium leading-snug tracking-wide">Hosted Groups</p>
        </div>
      </div>

      <!-- Accordion details -->
      <div class="border-t border-[#C5A44E]/20">
        {statesmanDetails.map(({ title, items }) => (
          <details class="group border-b border-[#C5A44E]/20">
            <summary class="flex items-center justify-between gap-4 py-6 cursor-pointer list-none">
              <h3 class="font-heading text-lg sm:text-xl text-white font-medium">{title}</h3>
              <svg class="w-4 h-4 flex-shrink-0 text-[#C5A44E] transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <ul class="pb-7 space-y-2 text-white/80 text-base leading-relaxed">
              {items.map((item) => (
                <li class="flex items-start">
                  <span class="text-[#C5A44E] mr-3 mt-2 flex-shrink-0 text-[6px]">&#9679;</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 4. HOSTED TABLE — cream with rich navy/gold accents -->
  <!-- ============================================================ -->
  <section id="hosted-tables" class="relative py-28 sm:py-36 bg-[#F7F3E8] overflow-hidden scroll-mt-24">
    <!-- Subtle parchment depth -->
    <div class="absolute inset-0 pointer-events-none opacity-30">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[60rem] h-[40rem] rounded-full opacity-40" style="background: radial-gradient(ellipse, rgba(197,164,78,0.15) 0%, transparent 70%); filter: blur(60px);"></div>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto px-6">
      <!-- Heading block -->
      <div class="text-center mb-14">
        <p class="text-[#C5A44E] font-medium tracking-[0.4em] uppercase text-[11px] mb-5">No. 02</p>
        <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold text-[#0B1F3A] leading-tight mb-6">
          Party Inside the Party
        </h2>
        <p class="font-heading italic text-[#163A70] text-lg sm:text-xl font-light leading-snug max-w-xl mx-auto mb-10">
          Start or join a Hosted Group in about 15 seconds. We take it from there.
        </p>

        <div class="flex items-center justify-center gap-4 mb-12">
          <div class="w-12 h-px bg-[#C5A44E]/70"></div>
          <div class="w-1.5 h-1.5 bg-[#C5A44E] rotate-45"></div>
          <div class="w-12 h-px bg-[#C5A44E]/70"></div>
        </div>

        <div class="space-y-4 text-[#163A70] text-lg leading-relaxed max-w-xl mx-auto">
          <p>An optional benefit for Statesman&rsquo;s Concierge Pass guests.</p>
          <p>Hosts invite their guests. Guests purchase their own qualifying passes. We coordinate the details.</p>
          <p class="text-[#163A70]/70 text-base italic">After purchase, guests receive simple follow-up instructions for starting their own Hosted Group or joining an existing one.</p>
        </div>
      </div>

      <!-- 3-step row on a navy panel for richness -->
      <div class="relative bg-gradient-to-br from-[#0B1F3A] via-[#163A70] to-[#0B1F3A] rounded-md overflow-hidden p-10 sm:p-12 mb-16 sm:mb-20 shadow-xl">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#C5A44E]/50 to-transparent"></div>
        <div class="grid sm:grid-cols-3 gap-10 sm:gap-6 text-center">
          <div>
            <p class="text-[#C5A44E] font-heading text-2xl font-light mb-3">01</p>
            <p class="text-white/95 text-sm sm:text-base font-medium tracking-wide leading-snug">Buy Statesman&rsquo;s Passes</p>
          </div>
          <div>
            <p class="text-[#C5A44E] font-heading text-2xl font-light mb-3">02</p>
            <p class="text-white/95 text-sm sm:text-base font-medium tracking-wide leading-snug">Start or Join a Group</p>
          </div>
          <div>
            <p class="text-[#C5A44E] font-heading text-2xl font-light mb-3">03</p>
            <p class="text-white/95 text-sm sm:text-base font-medium tracking-wide leading-snug">We Handle the Rest</p>
          </div>
        </div>
      </div>

      <!-- Two-column benefits (host + guest) -->
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 md:divide-x md:divide-[#0B1F3A]/15 mb-16">
        <div class="md:pr-4">
          <p class="text-[#C5A44E] font-medium tracking-[0.3em] uppercase text-[11px] mb-5">Why Hosts Love It</p>
          <ul class="space-y-2.5 text-[#163A70] text-base leading-relaxed">
            {hostBenefits.map((b) => (
              <li class="flex items-start">
                <span class="text-[#C5A44E] mr-3 mt-2 flex-shrink-0 text-[6px]">&#9679;</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="md:pl-12">
          <p class="text-[#C5A44E] font-medium tracking-[0.3em] uppercase text-[11px] mb-5">Why Guests Love It</p>
          <ul class="space-y-2.5 text-[#163A70] text-base leading-relaxed">
            {guestBenefits.map((b) => (
              <li class="flex items-start">
                <span class="text-[#C5A44E] mr-3 mt-2 flex-shrink-0 text-[6px]">&#9679;</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Seating note inline -->
      <div class="text-center pt-12 border-t border-[#0B1F3A]/15">
        <p class="text-[#C5A44E] font-medium tracking-[0.3em] uppercase text-[11px] mb-4">A Simple Seating Note</p>
        <p class="text-[#163A70] text-base sm:text-lg leading-relaxed max-w-xl mx-auto">
          Multiple Statesman&rsquo;s Passes purchased in one order are seated together. Guests not in a Hosted Group enjoy the full Statesman&rsquo;s experience in premium shared seating.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 5. FAQ — concise, calm rhythm -->
  <!-- ============================================================ -->
  <section class="py-24 sm:py-32 bg-[#F7F3E8]">
    <div class="max-w-2xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-[#C5A44E] font-medium tracking-[0.4em] uppercase text-[11px] mb-4">Common Questions</p>
        <h2 class="font-heading text-2xl sm:text-3xl text-[#0B1F3A] font-bold leading-tight">Everything Else You&rsquo;d Like to Know</h2>
      </div>

      <div class="border-t border-[#0B1F3A]/15">
        {faqs.map(({ q, a }) => (
          <details class="group border-b border-[#0B1F3A]/15">
            <summary class="flex items-start justify-between gap-6 py-5 sm:py-6 cursor-pointer list-none">
              <h3 class="font-heading text-base sm:text-lg text-[#0B1F3A] font-medium leading-snug">{q}</h3>
              <svg class="w-4 h-4 flex-shrink-0 text-[#C5A44E] mt-1.5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="pb-6 pr-10 text-[#163A70] text-base leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 6. FINAL CTA — third navy moment, page closes on the night -->
  <!-- ============================================================ -->
  <section class="relative py-32 sm:py-40 bg-gradient-to-b from-[#0B1F3A] via-[#163A70] to-[#0B1F3A] text-white overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[44rem] h-[44rem] rounded-full opacity-[0.14]" style="background: radial-gradient(circle, rgba(197,164,78,1) 0%, transparent 60%); filter: blur(55px);"></div>
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[32rem] h-[32rem] rounded-full opacity-[0.10]" style="background: radial-gradient(circle, rgba(197,164,78,1) 0%, transparent 60%); filter: blur(50px);"></div>
    </div>
