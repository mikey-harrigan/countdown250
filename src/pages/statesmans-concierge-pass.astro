    50%      { transform: translate(30px, -40px); opacity: 0.95; }
  }

  /* SCREEN shimmer — extremely subtle warm pulse on the headline
     "screen" so it feels backlit and alive. */
  .stage-screen {
    animation: screen-pulse 6s ease-in-out infinite;
  }
  @keyframes screen-pulse {
    0%, 100% { filter: brightness(1.0); }
    50%      { filter: brightness(1.04); }
