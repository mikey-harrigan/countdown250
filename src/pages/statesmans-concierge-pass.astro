  }

  /* HOT SPOTS — bright pools of light where cones hit the stage.
     These drift independently for added stage liveness. */
  .hotspot {
    will-change: transform, opacity;
  }
  .hotspot-1 {
    top: 35%;
    left: 25%;
    animation: hotspot-drift-1 8s ease-in-out infinite;
  }
  .hotspot-2 {
    top: 50%;
    left: 65%;
    animation: hotspot-drift-2 10s ease-in-out infinite;
  }
  .hotspot-3 {
    top: 30%;
    left: 60%;
    animation: hotspot-drift-3 12s ease-in-out infinite;
  }

  @keyframes hotspot-drift-1 {
    0%, 100% { transform: translate(0, 0); opacity: 0.7; }
    50%      { transform: translate(40px, 30px); opacity: 1.0; }
  }
  @keyframes hotspot-drift-2 {
