     stage where they cross. */
  .cone {
    position: absolute;
    pointer-events: none;
    top: -2rem;
    width: 14rem;
    height: 110%;
    transform-origin: 50% 0;
    filter: blur(22px);
    clip-path: polygon(45% 0%, 55% 0%, 100% 100%, 0% 100%);
    mix-blend-mode: screen;
    will-change: transform, opacity;
  }
  .cone-white-1 {
    left: 18%;
    background: linear-gradient(180deg, rgba(255,250,230,1) 0%, rgba(255,245,210,0.55) 30%, rgba(255,245,210,0.15) 60%, transparent 95%);
    animation: cone-sway-1 9s ease-in-out infinite;
  }
  .cone-gold {
    left: 38%;
    background: linear-gradient(180deg, rgba(255,210,130,1) 0%, rgba(197,164,78,0.55) 30%, rgba(197,164,78,0.15) 60%, transparent 95%);
    animation: cone-sway-2 11s ease-in-out infinite;
  }
  .cone-red {
    left: 60%;
    background: linear-gradient(180deg, rgba(230,90,100,1) 0%, rgba(180,30,45,0.5) 30%, rgba(166,30,45,0.15) 60%, transparent 95%);
    animation: cone-sway-3 13s ease-in-out infinite;
  }
  .cone-blue {
    left: 78%;
    background: linear-gradient(180deg, rgba(120,180,240,1) 0%, rgba(60,110,200,0.5) 30%, rgba(60,110,200,0.15) 60%, transparent 95%);
    animation: cone-sway-4 14s ease-in-out infinite;
  }
  .cone-white-2 {
    left: 50%;
    background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(255,255,255,0.4) 30%, rgba(255,255,255,0.1) 60%, transparent 95%);
    animation: cone-sway-5 16s ease-in-out infinite;
  }

  @keyframes cone-sway-1 {
    0%, 100% { transform: translateX(-50%) rotate(20deg); }
    50%      { transform: translateX(-50%) rotate(-5deg); }
  }
  @keyframes cone-sway-2 {
    0%, 100% { transform: translateX(-50%) rotate(-12deg); }
    50%      { transform: translateX(-50%) rotate(10deg); }
  }
  @keyframes cone-sway-3 {
    0%, 100% { transform: translateX(-50%) rotate(-22deg); }
    50%      { transform: translateX(-50%) rotate(8deg); }
