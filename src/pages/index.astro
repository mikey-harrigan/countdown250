---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import Venue from '../components/Venue.astro';
import Guests from '../components/Guests.astro';
import Tickets from '../components/Tickets.astro';
import Countdown from '../components/Countdown.astro';
import Gallery from '../components/Gallery.astro';
import Heroes from '../components/Heroes.astro';
import UpdatesPreview from '../components/UpdatesPreview.astro';
import NewsTicker from '../components/NewsTicker.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="All-American Countdown 250 Ball | July 3, 2026 | Washington, D.C."
  description="A once-in-a-generation patriotic celebration launching America's 250th anniversary weekend. July 3, 2026 at the Washington Hilton. 3,000 guests, 6 party zones, 4 stages, midnight countdown."
  ogImage="/images/event/hero-toast.png"
>
  <Navbar />
  <main>
    <Hero />
    <NewsTicker />
    <Countdown />
    <About />
    <Experience />
    <Heroes />
    <Guests />
    <Venue />
    <Tickets />
    <UpdatesPreview />
    <Gallery />
  </main>
  <Footer />
</BaseLayout>
