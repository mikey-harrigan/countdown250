---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import Venue from '../components/Venue.astro';
import Tickets from '../components/Tickets.astro';
import Countdown from '../components/Countdown.astro';
import Heroes from '../components/Heroes.astro';
import NewsTicker from '../components/NewsTicker.astro';
import Footer from '../components/Footer.astro';
import SocialProof from '../components/SocialProof.astro';
import HostedGroupsCallout from '../components/HostedGroupsCallout.astro';
---

<BaseLayout
  title="The Official Countdown 250 Ball | America 250 Gala | July 3, 2026 | Washington, D.C."
  description="The Official Countdown 250 Ball — Washington's premier America 250 black-tie gala at the legendary Washington Hilton. July 3, 2026. Live entertainment, premium open bars, and a midnight countdown to America's 250th birthday."
  ogImage="/images/event/hero-countdown250-toast.png"
>
  <Navbar />
  <main>
    <Hero />
    <SocialProof />
    <NewsTicker />
    <Countdown />
    <About />
    <Experience />
    <Heroes />
    <HostedGroupsCallout />
    <Tickets />
    <Venue />
  </main>
  <Footer />
</BaseLayout>
