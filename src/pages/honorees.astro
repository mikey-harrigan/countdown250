---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const pastCategories = [
  {
    icon: "🎖️",
    title: "Military & Veterans",
    desc: "Those who have served our nation in uniform with extraordinary distinction"
  },
  {
    icon: "🚒",
    title: "First Responders",
    desc: "Police officers, firefighters, paramedics, and others who protect our communities every day"
  },
  {
    icon: "🏥",
    title: "Healthcare & Medicine",
    desc: "Medical professionals whose innovations and compassion have saved countless lives"
  },
  {
    icon: "📚",
    title: "Education & Mentorship",
    desc: "Teachers, coaches, and mentors who shape the next generation of American leaders"
  },
  {
    icon: "🤝",
    title: "Community Service & Philanthropy",
    desc: "Citizens whose generosity and volunteer efforts have strengthened communities across America"
  },
  {
    icon: "🇺🇸",
    title: "Public Service & Leadership",
    desc: "Leaders in government and civic life who have dedicated their careers to the public good"
  },
];
---

<BaseLayout title="All-American Heroes | Countdown 250 Ball" description="Learn about the All-American Hero Lifetime Achievement Awards, past honorees, and how to nominate an extraordinary American for recognition at the Countdown 250 Ball.">
  <Navbar />
  <main>
    <!-- Hero header -->
    <section class="relative pt-32 pb-20 bg-navy text-white overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-navy-dark/90 to-navy"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-4">Honoring Those Who Serve</p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-4 font-heading">All-American Heroes</h1>
        <div class="w-20 h-1 bg-red mx-auto mb-6"></div>
        <p class="text-white/70 text-lg max-w-2xl mx-auto">Recognizing extraordinary Americans whose lifetime of service, sacrifice, and leadership embodies the very best of our nation.</p>
      </div>
    </section>

    <!-- About the Awards -->
    <section class="py-20 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-navy mb-6 font-heading">The All-American Hero Lifetime Achievement Awards</h2>
          <div class="w-16 h-1 bg-gold mx-auto"></div>
        </div>

        <div class="text-slate/70 text-lg leading-relaxed space-y-6">
          <p>
            Every four years, in conjunction with the Presidential Inauguration, the All-American Ball presents the
            <strong class="text-navy">All-American Hero Lifetime Achievement Awards</strong> to a select group of
            individuals who have dedicated their lives to serving others. These awards honor Americans whose courage,
            commitment, and selflessness have made a lasting impact on our nation.
          </p>
          <p>
            At the <strong class="text-navy">All-American Countdown 250 Ball</strong> on July 3, 2026, we will
            continue this proud tradition — presenting Lifetime Achievement Awards to outstanding citizens who
            represent the very best of America as we launch the nation's historic 250th anniversary weekend.
          </p>
          <p>
            Past honorees have included decorated military heroes, pioneering first responders, groundbreaking
            educators, tireless community leaders, and other extraordinary Americans whose stories inspire us all.
            Each honoree is recognized on stage during a stirring awards ceremony that is one of the most powerful
            and memorable moments of the evening.
          </p>
        </div>
      </div>
    </section>

    <!-- Past Categories -->
    <section class="py-20 bg-cream">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-navy mb-4 font-heading">Fields of Service</h2>
          <p class="text-slate/60 text-lg max-w-2xl mx-auto">All-American Hero Award recipients can come from any background or career, but all share a common thread — a lifetime of extraordinary service to others.</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {pastCategories.map((cat) => (
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate/5">
              <div class="text-3xl mb-3">{cat.icon}</div>
              <h3 class="text-lg font-bold text-navy mb-2">{cat.title}</h3>
              <p class="text-slate/60 text-sm leading-relaxed">{cat.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- What Makes an All-American Hero -->
    <section class="py-20 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-navy mb-4 font-heading">What Makes an All-American Hero?</h2>
          <div class="w-16 h-1 bg-gold mx-auto"></div>
        </div>

        <div class="text-slate/70 text-lg leading-relaxed mb-10">
          <p>Award recipients are chosen based on the following criteria:</p>
        </div>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-red/10 flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-red font-bold text-sm">1</span>
            </div>
            <div>
              <h3 class="font-bold text-navy text-lg mb-1">Lifetime of Service</h3>
              <p class="text-slate/60">A sustained, long-term commitment to serving others — not a single act, but a lifetime of dedication.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-red/10 flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-red font-bold text-sm">2</span>
            </div>
            <div>
              <h3 class="font-bold text-navy text-lg mb-1">Selflessness & Sacrifice</h3>
              <p class="text-slate/60">A demonstrated pattern of putting others before oneself, often at personal cost or risk.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-red/10 flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-red font-bold text-sm">3</span>
            </div>
            <div>
              <h3 class="font-bold text-navy text-lg mb-1">Lasting Impact</h3>
              <p class="text-slate/60">Contributions that have made a measurable, lasting difference in their community, field, or the nation as a whole.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-red/10 flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-red font-bold text-sm">4</span>
            </div>
            <div>
              <h3 class="font-bold text-navy text-lg mb-1">Exemplary Character</h3>
              <p class="text-slate/60">Integrity, courage, and moral leadership that inspires others to serve and make a difference.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-red/10 flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-red font-bold text-sm">5</span>
            </div>
            <div>
              <h3 class="font-bold text-navy text-lg mb-1">Embodies the American Spirit</h3>
              <p class="text-slate/60">Represents the values of courage, resilience, generosity, and patriotism that define the best of America.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Nominations -->
    <section class="py-20 bg-navy text-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-4">Nominations Now Open</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6 font-heading">Nominate an All-American Hero</h2>
        <div class="w-16 h-1 bg-gold mx-auto mb-8"></div>

        <div class="text-white/70 text-lg leading-relaxed space-y-6 text-left max-w-2xl mx-auto mb-12">
          <p>
            We are now accepting nominations for the 2026 All-American Hero Lifetime Achievement Awards.
            Do you know someone who has dedicated their life to serving others? Someone whose courage,
            sacrifice, and commitment have made a real difference?
          </p>
          <p>
            We invite you to submit their name for consideration. Nominees can come from any background,
            profession, or walk of life — what matters is their lifetime of extraordinary service.
          </p>
          <p class="text-white/50 text-base">
            <strong class="text-white/70">To submit a nomination, please include:</strong>
          </p>
          <ul class="text-white/60 text-base space-y-2 list-none">
            <li class="flex items-start gap-3">
              <span class="text-gold mt-0.5">★</span>
              <span>Nominee's full name and location</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold mt-0.5">★</span>
              <span>Their field of service</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold mt-0.5">★</span>
              <span>A brief description of their lifetime of contributions (250 words or less)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold mt-0.5">★</span>
              <span>Why you believe they exemplify the spirit of an All-American Hero</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold mt-0.5">★</span>
              <span>Your name and contact information</span>
            </li>
          </ul>
        </div>

        <a
          href="mailto:heroes@allamericanball.com?subject=All-American%20Hero%20Nomination"
          class="inline-block bg-red hover:bg-red-light text-white px-10 py-4 text-lg font-semibold tracking-wider uppercase transition-all rounded shadow-lg hover:-translate-y-0.5"
        >
          Submit a Nomination
        </a>
        <p class="text-white/40 text-sm mt-4">Nominations will be reviewed by our Awards Committee. All submissions are confidential.</p>
      </div>
    </section>

    <!-- 2026 Honorees Teaser -->
    <section class="py-20 bg-cream">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-navy mb-6 font-heading">2026 Honorees</h2>
        <div class="w-16 h-1 bg-gold mx-auto mb-8"></div>
        <div class="bg-white rounded-2xl p-10 shadow-sm border border-slate/5">
          <svg class="w-12 h-12 text-gold mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
          <h3 class="text-xl font-bold text-navy mb-3">Coming Soon</h3>
          <p class="text-slate/60 text-lg">
            The 2026 All-American Hero Lifetime Achievement Award honorees will be announced as the event approaches.
            Follow us on social media and check our <a href="/updates/" class="text-red hover:text-red-light underline">News & Updates</a> page for announcements.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-red text-center">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4 font-heading">Be There for the Awards Ceremony</h2>
        <p class="text-white/80 mb-6">
          Witness these extraordinary Americans receive their Lifetime Achievement Awards in person at the Countdown 250 Ball.
        </p>
        <a
          href="/#tickets"
          class="inline-block bg-white text-red px-10 py-4 text-lg font-semibold tracking-wider uppercase hover:bg-cream transition-colors rounded shadow-lg"
        >
          Get Your Tickets
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
