---
// =============================================================================
// ARCHIVED HOMEPAGE — DO NOT REMOVE
// =============================================================================
// This is a verbatim copy of the live homepage as it existed BEFORE the
// 2026-04-26 swap to the conversion-focused inline layout. Saved at Mike's
// explicit request as a reference for future ideas and as a fallback.
//
// To view: visit countdown250.allamericanball.com/home-original-archive/
// To restore as live home: copy this file's contents into src/pages/index.astro
//
// When Mike says "show me the original home page" or anything similar, this
// is the file/URL to point him to.
// =============================================================================
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import Venue from '../components/Venue.astro';
import Tickets from '../components/Tickets.astro';
import Countdown from '../components/Countdown.astro';
import Heroes from '../components/Heroes.astro';
import NewsTicker from '../components/NewsTicker.astro';
import Footer from '../components/Footer.astro';
import SocialProof from '../components/SocialProof.astro';
import HostedGroupsCallout from '../components/HostedGroupsCallout.astro';
---

<BaseLayout
  title="Original Home (Archive) | Countdown 250 Ball"
  description="Archived copy of the original Countdown 250 Ball homepage — preserved for reference."
  ogImage="/images/event/hero-countdown250-toast.png"
>
  <!-- Tell search engines not to index this archival URL -->
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <Navbar />

  <!-- Small banner identifying this as the archive -->
  <div class="bg-gold/15 border-b border-gold/40 text-navy py-3 text-center text-sm">
    <p class="font-semibold tracking-wide">
      ARCHIVE &mdash; Original home page (pre &middot; 2026-04-26).
      <a href="/" class="underline hover:text-red ml-2">View current live home &rarr;</a>
    </p>
  </div>

  <main>
    <Hero />
    <SocialProof />
    <NewsTicker />
    <Countdown />
    <About />
    <Experience />
    <Heroes />
    <HostedGroupsCallout />
    <Tickets />
    <Venue />
  </main>
  <Footer />
</BaseLayout>
