---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Press & Media | All-American Countdown 250 Ball" description="Press and media information for the All-American Countdown 250 Ball on July 3, 2026 at the Washington Hilton." ogImage="/images/event/ballroom-crowd.jpg">
  <Navbar />
  <main>
    <section class="relative pt-32 pb-20 bg-navy text-white overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-navy-dark/90 to-navy"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-4">Media Resources & Coverage</p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-4 font-heading">Press & Media</h1>
        <div class="w-20 h-1 bg-red mx-auto"></div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold text-navy mb-6 font-heading">Media Information</h2>
          <div class="w-16 h-1 bg-gold mx-auto"></div>
        </div>

        <div class="text-slate/70 text-lg leading-relaxed space-y-6 mb-16">
          <p>
            The All-American Countdown 250 Ball is one of the premier celebrations launching
            America's 250th anniversary weekend on July 3, 2026 at the historic Washington Hilton
            in Washington, D.C. With an expected 3,000 guests including leaders, dignitaries,
            entertainers, decorated veterans, and proud Americans from across the nation, this
            is a story worth covering.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-6 mb-16">
          <div class="bg-cream rounded-xl p-6">
            <div class="text-3xl mb-3">📰</div>
            <h3 class="text-lg font-bold text-navy mb-2">Press Inquiries</h3>
            <p class="text-slate/60 text-sm">For interviews, press passes, and media inquiries, please contact our communications team.</p>
          </div>
          <div class="bg-cream rounded-xl p-6">
            <div class="text-3xl mb-3">📸</div>
            <h3 class="text-lg font-bold text-navy mb-2">Media Credentials</h3>
            <p class="text-slate/60 text-sm">Credentialed media may apply for event access. Applications will open closer to the event.</p>
          </div>
          <div class="bg-cream rounded-xl p-6">
            <div class="text-3xl mb-3">📁</div>
            <h3 class="text-lg font-bold text-navy mb-2">Press Kit</h3>
            <p class="text-slate/60 text-sm">A downloadable press kit with logos, event details, and high-resolution images will be available soon.</p>
          </div>
          <div class="bg-cream rounded-xl p-6">
            <div class="text-3xl mb-3">📺</div>
            <h3 class="text-lg font-bold text-navy mb-2">Broadcast & Webcast</h3>
            <p class="text-slate/60 text-sm">Details about live broadcast and webcast partnerships will be announced in the coming weeks.</p>
          </div>
        </div>

        <!-- Press Release -->
        <div class="mb-16">
          <h2 class="text-3xl font-bold text-navy mb-8 font-heading">Latest Press Release</h2>
          <div class="bg-cream rounded-2xl p-8 sm:p-10">
            <p class="text-gold font-medium tracking-[0.2em] uppercase text-xs mb-3">For Immediate Release</p>
            <h3 class="text-xl sm:text-2xl font-bold text-navy mb-6 font-heading leading-tight">All-American Countdown 250 Ball to Host 3,000 Guests at Washington Hilton for Historic Celebration Launching America's 250th Anniversary Weekend</h3>
            <p class="text-slate/50 text-sm italic mb-6">Once-in-a-Generation Black-Tie Gala Features Live Entertainment Across 4 Stages, 6 Party Zones, Midnight Countdown, and the All-American Hero Lifetime Achievement Awards</p>

            <div class="text-slate/70 text-base leading-relaxed space-y-4">
              <p><strong class="text-navy">WASHINGTON, D.C.</strong> — The All-American Countdown 250 Ball, the premier gala event launching America's 250th anniversary weekend, will take place on the evening of July 3, 2026 at the iconic Washington Hilton in Washington, D.C. An expected 3,000 guests — including dignitaries, military leaders, media personalities, and distinguished citizens from across the nation — will gather for an extraordinary evening of patriotism, entertainment, and celebration as the nation counts down to its historic semiquincentennial.</p>

              <p>"This is the event of a generation," said Mike Harrigan, Founder of GoCity Group, the event's organizer. "On the eve of America's 250th birthday, we are bringing together thousands of Americans from every walk of life for a night they will never forget. This will be a carnival of the senses — an evening of spectacle, patriotism, and pure celebration unlike anything Washington has ever seen."</p>

              <p>"Our goal is simple," Harrigan added. "We want every single guest to walk out of the Washington Hilton with the greatest memories of their lives. Every detail — from the entertainment to the midnight countdown to the way we treat our guests — is being designed to deliver an experience that is truly once in a lifetime."</p>

              <h4 class="text-lg font-bold text-navy pt-4">A Carnival of the Senses</h4>
              <p>The Countdown 250 Ball promises an unparalleled sensory experience spanning the Washington Hilton's grand event spaces, including live entertainment across 4 stages, 6 immersive party zones, a premium open bar all night, roaming entertainers and immersive experiences, and a stirring Patriotic Tribute to America honoring 250 years of American history.</p>

              <p>The signature moment of the evening will be a breathtaking midnight countdown — not a standard ball drop or balloon release, but a multi-sensory production of patriotic grandeur marking the exact instant America enters its 250th year.</p>

              <h4 class="text-lg font-bold text-navy pt-4">All-American Hero Lifetime Achievement Awards</h4>
              <p>A highlight of the evening will be the presentation of the All-American Hero Lifetime Achievement Awards, recognizing extraordinary Americans whose lifetime of service, sacrifice, and leadership embodies the best of the nation. The public is invited to nominate deserving individuals at the event website.</p>

              <h4 class="text-lg font-bold text-navy pt-4">Ticket Information</h4>
              <p>Three ticket tiers are available — the Liberty Ticket ($195), Patriot VIP Ticket ($395), and the Statesman's Concierge Pass ($1,495). Corporate sponsorship and premium host packages are available by contacting CountdownAmerica250@gmail.com. Ticket sales are being deliberately limited to ensure optimal comfort and an exceptional experience for every guest. Prices are expected to increase as the event approaches.</p>
            </div>

            <div class="mt-8 pt-6 border-t border-slate/10">
              <p class="text-sm text-slate/50"><strong class="text-navy">Media Contact:</strong> Mike Harrigan, Founder, GoCity Group</p>
              <p class="text-sm text-slate/50">CountdownAmerica250@gmail.com | 703-930-0400 (media inquiries only)</p>
            </div>
          </div>
        </div>

        <div class="bg-navy rounded-2xl p-10 text-center">
          <svg class="w-12 h-12 text-gold mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
          <h3 class="text-xl font-bold text-gold mb-3">Press Credentials & Media Access</h3>
          <p class="text-white/70 text-lg mb-6">
            For interviews, press passes, media credentials, and additional resources, contact our press team.
          </p>
          <a href="mailto:CountdownAmerica250@gmail.com?subject=Press%20Inquiry%20-%20Countdown%20250%20Ball" class="inline-block bg-red hover:bg-red-light text-white px-8 py-3 text-sm font-semibold tracking-wider uppercase transition-all rounded shadow-lg hover:-translate-y-0.5">
            Contact Press Team
          </a>
        </div>

        <div class="text-center mt-12">
          <a href="/" class="inline-block bg-white border-2 border-navy text-navy hover:bg-navy hover:text-white px-8 py-3 text-sm font-semibold tracking-wider uppercase transition-all rounded hover:-translate-y-0.5">
            Back to Home
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
