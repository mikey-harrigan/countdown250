---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { updates } from '../data/updates';

function formatDate(dateStr: string): string {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title="News & Announcements | All-American Countdown 250 Ball"
  description="Latest news and announcements for the All-American Countdown 250 Ball on July 3, 2026 at the Washington Hilton."
>
  <Navbar />
  <main>
    <!-- Header -->
    <section class="relative pt-32 pb-20 bg-navy text-white overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-navy-dark/90 to-navy"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-4">Stay Informed</p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-4 font-heading">News & Announcements</h1>
        <div class="w-20 h-1 bg-red mx-auto"></div>
      </div>
    </section>

    <!-- Updates list -->
    <section class="py-16 sm:py-24 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="space-y-0">
          {updates.map((update, i) => (
            <article class={`py-8 ${i > 0 ? 'border-t border-slate/10' : ''}`}>
              <time class="text-sm text-gold font-medium tracking-wider uppercase">{formatDate(update.date)}</time>
              <h2 class="text-2xl font-bold text-navy mt-2 mb-4 font-heading">{update.headline}</h2>
              <p class="text-slate/70 text-lg leading-relaxed">{update.body}</p>
            </article>
          ))}
        </div>

        <div class="text-center mt-12 pt-8 border-t border-slate/10">
          <p class="text-slate/50 text-sm italic mb-6">More updates will be posted as the event approaches.</p>
          <a
            href="/"
            class="inline-block bg-red hover:bg-red-light text-white px-8 py-3 text-sm font-semibold tracking-wider uppercase transition-all rounded shadow-lg hover:-translate-y-0.5"
          >
            Back to Home
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
