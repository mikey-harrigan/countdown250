---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="About — The Official Countdown 250 Ball | The Can't-Miss Event of a Lifetime | Washington D.C. July 3, 2026"
  description="The Countdown 250 Ball is the can't-miss event of a lifetime — America's formal evening kickoff to the 250th anniversary, July 3, 2026 at the Washington Hilton. 3,000 guests. 6 ballrooms. 4 stages. The stroke of midnight launches America 250."
  ogImage="/images/event/stage-countdown-v2.png"
>
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-32 pb-16 bg-navy-dark text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, rgba(197,164,78,0.3) 0%, transparent 70%);"></div>
    </div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center relative z-10">
      <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-4">July 3, 2026 &middot; Washington Hilton</p>
      <h1 class="text-3xl sm:text-5xl font-bold mb-4 font-heading">The Countdown Is On</h1>
      <p class="text-xl sm:text-2xl text-gold/90 italic font-light mb-8">America&rsquo;s Formal Kickoff to the 250th</p>
      <div class="w-24 h-0.5 bg-gold mx-auto"></div>
    </div>
  </section>

  <!-- Legacy credibility intro (short bridge) -->
  <section class="py-14 bg-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-red text-base md:text-lg font-semibold italic leading-relaxed">
        From inaugural balls to milestone events, the All-American Ball Committee has produced some of America&rsquo;s most historic celebrations &mdash; bringing together leaders, dignitaries, astronauts, world-champion athletes, A-list celebrities, members of Congress, and proud Americans for over three decades.
      </p>
    </div>
  </section>

  <!-- ACT 1: The Moment -->
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <p class="text-red font-semibold tracking-[0.3em] uppercase text-xs mb-4 text-center">Act One</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-8 font-heading text-center leading-tight">The Moment</h2>

      <div class="space-y-6 text-lg text-slate leading-relaxed">
        <p>
          <strong class="text-navy">America 250</strong> &mdash; the 250th anniversary of the United States &mdash; is the most anticipated national milestone of our lifetimes. The entire country marks the occasion this Independence Weekend, and Washington, D.C. will be ground zero.
        </p>
        <p>
          People who experienced the Bicentennial in 1976 still talk about it. Half a century on, they remember exactly where they were the night America turned 200. <strong class="text-navy">That moment defined a generation.</strong>
        </p>
        <p class="text-xl font-semibold text-navy text-center pt-4 border-t border-navy/10">
          This is that moment for us.
        </p>
      </div>
    </div>
  </section>

  <!-- ACT 2: The Production -->
  <section class="py-16 sm:py-20 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <p class="text-red font-semibold tracking-[0.3em] uppercase text-xs mb-4 text-center">Act Two</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-8 font-heading text-center leading-tight">The Production</h2>

      <div class="space-y-6 text-lg text-slate leading-relaxed">
        <p>
          For 30+ years our team has produced the events that mark America&rsquo;s most important nights &mdash; Inaugural Balls, milestone anniversaries, and signature Washington galas. Presidents, members of Congress, astronauts, decorated veterans, world-champion athletes, dignitaries, and entertainers from every corner of American life have walked through our doors.
        </p>
        <p>
          A celebration of this magnitude can only take place at one venue: the legendary <a href="/venue" class="text-red font-semibold hover:underline">Washington Hilton</a> &mdash; the iconic site of the White House Correspondents&rsquo; Dinner and over 60 years of presidential history.
        </p>
        <p>
          Ball week falls during the <a href="/great-american-state-fair-evening" class="text-red font-semibold hover:underline">Great American State Fair</a> on the National Mall &mdash; 16 days bringing all 50 states, territories, and federal agencies to the capital. By day, the Fair. By night, the Ball. Three blocks apart.
        </p>
        <p class="text-xl font-semibold text-navy text-center pt-4 border-t border-navy/15">
          Everything we&rsquo;ve produced over three decades was prologue to one night.
        </p>
      </div>
    </div>
  </section>

  <!-- ACT 3: THE CRESCENDO — The Countdown 250 Ball -->
  <section class="relative py-20 sm:py-28 bg-gradient-to-b from-navy-dark via-navy to-navy-dark text-white overflow-hidden">
    <!-- Gold edge accents -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/60 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/60 to-transparent"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-gold font-bold tracking-[0.4em] uppercase text-xs sm:text-sm mb-5">The Event</p>

      <h2 class="font-heading font-bold leading-[1.05] mb-4 tracking-tight text-4xl sm:text-5xl md:text-6xl lg:text-7xl">
        The Countdown 250 Ball
      </h2>

      <p class="font-heading italic text-gold/95 text-2xl sm:text-3xl md:text-4xl font-light leading-tight mb-10">
        The Can&rsquo;t-Miss Event of a Lifetime
      </p>

      <div class="w-24 h-0.5 bg-gold mx-auto mb-10"></div>

      <div class="space-y-6 text-lg sm:text-xl text-white/90 leading-relaxed text-left max-w-3xl mx-auto">
        <p>
          On the evening of July 3, 2026, the Washington Hilton transforms into the largest, most consequential evening kickoff to America 250 weekend.
        </p>
        <p>
          <strong class="text-white">3,000 guests. 6 grand ballrooms. 4 stages. Open bars all night. World-class entertainment from coast to coast. The All-American Hero Lifetime Achievement Awards. A Patriotic Tribute to America.</strong>
        </p>
        <p>
          And at the stroke of midnight &mdash; the moment America turns 250 &mdash; a countdown that launches the nation&rsquo;s 250th birthday from the ballroom floor.
        </p>
      </div>

      <!-- Punchline statements -->
      <div class="mt-12 pt-10 border-t border-gold/30 space-y-4">
        <p class="font-heading text-2xl sm:text-3xl md:text-4xl font-bold text-white leading-tight">
          This is not <em class="italic text-gold/90">a</em> gala.
        </p>
        <p class="font-heading text-2xl sm:text-3xl md:text-4xl font-bold text-white leading-tight">
          This is <em class="italic text-gold/90">the</em> gala.
        </p>
        <p class="font-heading italic text-gold/95 text-xl sm:text-2xl md:text-3xl font-light leading-snug pt-6">
          The night your grandchildren will ask you about.
        </p>
      </div>

      <!-- Final emotional close -->
      <div class="mt-12 pt-10 border-t border-gold/30">
        <p class="text-white/95 text-lg sm:text-xl leading-relaxed mb-6 max-w-2xl mx-auto">
          Forty years from now, you will remember exactly where you were when the clock struck 250.
        </p>
        <p class="font-heading italic text-gold text-2xl sm:text-3xl md:text-4xl font-bold leading-snug">
          Be in the room when it happens.
        </p>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="py-16 bg-red text-white text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl font-bold mb-3 font-heading">Don&rsquo;t Miss It.</h2>
      <p class="text-white/90 text-base sm:text-lg mb-8">Tickets are limited and prices rise as inventory shrinks.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#tickets" class="bg-white text-red px-10 py-4 text-sm font-bold tracking-[0.2em] uppercase hover:bg-cream transition-colors rounded shadow-lg">Compare Ticket Options</a>
        <a href="/venue" class="border-2 border-white text-white px-10 py-4 text-sm font-semibold tracking-[0.2em] uppercase hover:bg-white hover:text-red transition-colors rounded">About the Venue</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
