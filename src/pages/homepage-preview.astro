---

<BaseLayout
  title="Countdown 250 Ball — Homepage Preview | Washington Hilton | July 3, 2026"
  description="Conversion-focused homepage preview for The Official Countdown 250 Ball. Washington Hilton, July 3, 2026. America's premier July 3 celebration."
  ogImage="/images/event/hero-countdown250-toast.png"
>
  <Navbar />

  <main>
    <!-- ============================================================ -->
    <!-- 1. HERO -->
    <!-- ============================================================ -->
    <section class="relative min-h-[100vh] flex items-center justify-center overflow-hidden">
      <!-- Background image -->
      <div class="absolute inset-0">
        <img
          src="/images/event/hero-countdown250-toast.png"
          alt="Black-tie guests toasting with champagne as Countdown 250 reaches 00:00:01 on stage"
          class="w-full h-full object-cover object-center"
        />
        <div class="absolute inset-0" style="background: rgba(0,0,0,0.55);"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 text-center px-4 sm:px-6 max-w-5xl mx-auto pt-28 pb-20">
        <!-- Seal logo -->
        <div class="flex justify-center mb-10 animate-fade-in">
          <img
            src="/images/logos/countdown250-seal-circle-dark.png"
            alt="The Official Countdown 250 Ball — July 3, 2026 — Washington, D.C."
            class="w-[240px] sm:w-[300px] md:w-[340px] h-auto drop-shadow-2xl"
          />
        </div>

        <!-- Poetic open: italic question, two staggered lines -->
        <p class="font-heading italic font-light text-2xl sm:text-3xl md:text-4xl text-white/85 leading-tight mb-1 tracking-tight">
          Where will you be&hellip;
        </p>
        <p class="font-heading italic font-normal text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-white leading-tight mb-12 tracking-tight">
          when the clock strikes 250?
        </p>

        <!-- Masthead presentational line -->
        <p class="font-heading italic font-bold text-xl sm:text-2xl md:text-3xl text-gold mb-2 tracking-wide">
          The Official
        </p>

        <!-- Display headline -->
        <h1 class="font-heading font-bold text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] text-white leading-[1.05] mb-7 tracking-tight">
          Countdown 250 Ball
        </h1>

        <!-- Gold flourish divider -->
        <div class="w-20 h-px bg-gold/70 mx-auto mb-6"></div>

        <!-- Italic close -->
        <p class="font-heading italic font-light text-lg sm:text-xl md:text-2xl text-gold/95 mb-12">
          A once-in-a-lifetime moment.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a
            href={ticketUrl}
            class="eventbrite-checkout bg-red hover:bg-red-light text-white px-10 py-4 text-sm font-semibold tracking-[0.2em] uppercase transition-all rounded shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          >
            Get Tickets
          </a>
          <a
            href="#statesman"
            class="border-2 border-gold text-gold hover:bg-gold hover:text-navy-dark px-10 py-4 text-sm font-semibold tracking-[0.2em] uppercase transition-all rounded"
          >
            Explore Statesman's Experience
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 1.5 TRUST BAND — three-line hierarchy: lead-in + hero + trust line -->
    <!-- ============================================================ -->
    <section class="relative bg-white border-y border-gold/30">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10 text-center">
        <!-- Line 1: supportive lead-in (italic, lighter, smaller) -->
        <p class="text-navy/65 text-sm sm:text-base md:text-lg font-medium italic tracking-wide mb-1.5">
          America&rsquo;s Formal Kickoff to the
        </p>
        <!-- Line 2: hero positioning statement (largest / strongest) -->
        <p class="font-extrabold text-navy text-2xl sm:text-3xl md:text-4xl leading-tight tracking-tight mb-4">
          Biggest Celebration in American History
        </p>
        <!-- Line 3: trust / credentials line (tracked editorial uppercase) -->
        <p class="text-navy/70 text-[11px] sm:text-xs font-semibold tracking-[0.25em] uppercase">
          Washington Hilton <span class="text-gold mx-3">&#10022;</span> Supporting Operation Renewed Hope Foundation
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 1.6 COUNTDOWN TIMER — premium, static-feeling band -->
    <!-- ============================================================ -->
    <Countdown />

    <!-- ============================================================ -->
    <!-- 3. ALL-INCLUSIVE EXPERIENCE -->
    <!-- ============================================================ -->
    <section id="experience" class="py-20 sm:py-28 bg-red">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Header + value-establishing copy -->
        <div class="text-center mb-14 sm:mb-16 max-w-3xl mx-auto">
          <p class="text-gold font-semibold tracking-[0.3em] uppercase text-xs mb-4">A Celebration for the Ages</p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-5 font-heading leading-tight">
            Your All-Inclusive Experience
          </h2>
          <div class="w-20 h-px bg-gold mx-auto mb-8"></div>
          <p class="text-white/90 text-lg leading-relaxed mb-5">
            On July 3, the iconic Washington Hilton ballroom complex will transform into an extraordinary celebration of American heritage &mdash; an evening of world-class entertainment, refined elegance, and memories that will last forever.
          </p>
          <p class="text-white/90 text-lg leading-relaxed">
            Mix and mingle with decorated veterans and first responders, professional athletes and celebrities, C-suite business leaders, policymakers, media personalities, influencers, and proud Americans from across the country at this once-in-a-lifetime celebration.
          </p>
        </div>

        <!-- Compact feature cards: icon + title inline, description indented below -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {experienceFeatures.map((f) => (
            <div class="bg-white rounded-xl border border-navy/25 px-5 py-4 hover:border-navy hover:-translate-y-0.5 transition-all shadow-[0_0_12px_rgba(13,61,122,0.15)] hover:shadow-[0_0_28px_rgba(13,61,122,0.4)]">
              <div class="flex items-center gap-3 mb-2">
                <div class="text-gold flex-shrink-0" set:html={experienceIcons[f.icon]} />
                <h3 class="font-heading font-bold text-navy text-base sm:text-lg leading-tight">{f.title}</h3>
              </div>
              <p class="text-slate/70 text-sm pl-10 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 4. TICKET LADDER — modernized 3-column comparison (restored) -->
    <!-- ============================================================ -->
    <section id="tickets" class="py-20 sm:py-28 bg-navy-dark text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="text-center mb-14">
          <p class="text-gold font-semibold tracking-[0.3em] uppercase text-xs mb-4">Early Release Pricing</p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-6 font-heading">Choose Your Ticket Type</h2>
          <div class="w-20 h-1 bg-red mx-auto mb-6"></div>
          <p class="text-white/60 text-sm max-w-lg mx-auto mb-4">
            Ticket sales are deliberately limited to ensure optimal comfort and an exceptional experience for every guest.
          </p>
          <p class="text-gold/80 text-sm max-w-xl mx-auto mb-6 font-medium">
            &#9733; Proceeds help support <a href="https://www.operationrenewedhopefoundation.org" target="_blank" rel="noopener noreferrer" class="underline hover:text-gold">Operation Renewed Hope Foundation</a> in their mission to house U.S. Veterans and end veteran homelessness.
          </p>
          <p class="text-white/60 text-base italic">Three Tiers of Tickets</p>
        </div>

        <!-- Tier indicator -->
        <div class="flex items-center justify-center gap-0 mb-12 max-w-4xl mx-auto">
          <div class="flex-1 h-1 bg-white/20 rounded-l-full"></div>
          {[1, 2, 3].map(() => (
            <div class="flex flex-col items-center mx-2 sm:mx-4">
              <div class="w-4 h-4 rounded-full border-2 bg-gold border-gold"></div>
            </div>
          ))}
          <div class="flex-1 h-1 bg-white/20 rounded-r-full"></div>
        </div>

        <!-- 3-column ticket grid (md+); stacks on mobile -->
        <div class="grid md:grid-cols-3 gap-6 sm:gap-8 lg:gap-10 mb-14 items-start">
          {tickets.map((ticket) => (
            <div id={ticket.id} class={`relative rounded-2xl overflow-hidden flex flex-col h-full transition-transform ${
              ticket.highlight
                ? 'bg-white text-slate ring-4 ring-gold shadow-[0_20px_60px_-15px_rgba(197,164,78,0.55)] md:scale-[1.03]'
                : 'bg-white/[0.04] border-2 border-white/15 text-white shadow-xl'
            }`}>
              {/* Tier header bar */}
              <div class={`py-2.5 text-center text-[11px] sm:text-xs font-bold tracking-widest uppercase ${
                ticket.highlight ? 'bg-gold text-navy-dark' : 'bg-white/10 text-white/60'
              }`}>
                {ticket.badge}
              </div>

              <div class="p-7 sm:p-8 flex flex-col flex-grow">
                {/* Time + Name */}
                <div class="mb-6">
                  <p class={`text-[11px] font-medium tracking-wider uppercase mb-2 ${ticket.highlight ? 'text-slate/50' : 'text-white/40'}`}>
                    {ticket.time}
                  </p>
                  <h3 class={`text-2xl font-bold mb-1 font-heading ${ticket.highlight ? 'text-navy' : 'text-white'}`}>
                    {ticket.name}
                  </h3>
                </div>

                {/* Hosted Group Tables badge — Statesman only */}
                {ticket.highlight && (
                  <a
                    href="/hosted-group-tables"
                    class="block mb-6 bg-gradient-to-r from-gold/15 via-gold/20 to-gold/15 border-2 border-gold/50 rounded-lg px-4 py-3 hover:border-gold hover:from-gold/25 hover:to-gold/25 transition-all group"
                  >
                    <div class="flex items-center gap-3">
                      <span class="flex-shrink-0 bg-red text-white text-[10px] font-bold tracking-wider uppercase px-2 py-0.5 rounded">New</span>
                      <div class="flex-1 min-w-0">
                        <p class="text-navy font-bold text-sm leading-tight">Hosted Group Tables</p>
                        <p class="text-slate/70 text-xs leading-tight mt-0.5">Gather your crew. Be named Founding Host. &rarr;</p>
                      </div>
                    </div>
