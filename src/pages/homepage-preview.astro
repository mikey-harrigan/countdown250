---
// STANDALONE PREVIEW PAGE — accessible only by direct URL.
// Not linked from the main navigation. A conversion-focused alternate
// homepage layout for evaluation before (potentially) replacing the live home.
//
// If testing well, the final swap is: move the <main> contents of this page
// into src/pages/index.astro. Do NOT remove this file at that point — keep
// it as a fallback/reference.
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const ticketUrl = "https://www.eventbrite.com/e/the-official-countdown-250-ball-washington-dc-tickets-1982528927390?aff=websitemain";

const energyFeatures = [
  { label: "6 Party Zones", icon: "ballrooms" },
  { label: "4 Stages", icon: "stages" },
  { label: "Live Bands & DJs", icon: "music" },
  { label: "Premium Bars", icon: "drink" },
  { label: "Fine Cuisine", icon: "dining" },
  { label: "3,000 Distinguished Guests", icon: "guests" },
  { label: "Midnight Celebration", icon: "sparkle" },
];

const tiers = [
  {
    name: "Liberty Ticket",
    tagline: "Full access to the celebration.",
    price: "$225",
    bullets: [
      "Main ballroom access",
      "Premium open bars",
      "Live bands & DJs",
      "Midnight countdown to America's 250th",
    ],
    scarcity: "Current Release Pricing",
    highlight: false,
    badge: "Tier 1",
  },
  {
    name: "Patriot VIP Experience",
    tagline: "Earlier entry and upgraded hospitality.",
    price: "$450",
    bullets: [
      "Everything in Liberty",
      "Early entry + VIP reception dinner",
      "Premium open bar",
      "Access to honored guests",
    ],
    scarcity: "Limited VIP Availability",
    highlight: false,
    badge: "Tier 2",
  },
  {
    name: "Statesman's Concierge Pass",
    tagline: "The definitive Countdown 250 experience.",
    price: "$1,700",
    bullets: [
      "Priority entry",
      "Premium hospitality",
      "Upgraded food & beverage",
      "Preferred access",
    ],
    scarcity: "Premium Allocation Limited",
    highlight: true,
    badge: "The Pinnacle",
  },
];

const trustPoints = [
  {
    title: "Iconic Washington Hilton",
    body: "The event is hosted at the landmark venue that has welcomed presidents, world leaders, and the White House Correspondents' Dinner for over 60 years.",
  },
  {
    title: "Supporting Operation Renewed Hope Foundation",
    body: "Proceeds help ORHF in their mission to house U.S. Veterans and end veteran homelessness.",
  },
  {
    title: "Produced by a Landmark Washington Team",
    body: "From the organizers of multiple All-American Inaugural Balls and three decades of premier DC galas — a track record of signature national-moment celebrations at the Washington Hilton and beyond.",
  },
  {
    title: "The Premier July 3 Kickoff",
    body: "The formal kickoff to America's 250th Independence Weekend — the once-in-a-generation moment you'll tell your grandchildren about.",
  },
];

const faqs = [
  {
    q: "Is this political?",
    a: "No. The Countdown 250 Ball is a non-partisan, multigenerational celebration of America's 250th anniversary. Guests come from every corner of American life — business, arts, military, civic life, and beyond.",
  },
  {
    q: "What is the dress code?",
    a: "Black-tie optional. Tuxedos and formal gowns are welcome and encouraged; tailored dark suits and sophisticated evening wear are equally appropriate. Military dress uniforms are respected and welcomed.",
  },
  {
    q: "What is included with the Statesman's Concierge Pass?",
    a: "Personal concierge service from arrival to departure, access to private areas historically reserved for presidents and other high-level dignitaries, premium bars and elevated food service throughout the night, a signature gift, and eligibility for Hosted Group Tables — the program that lets you gather your own group at a reserved table inside the Statesman's Concierge Area.",
  },
  {
    q: "Are hosted tables available?",
    a: "Yes. Hosted table placements are available for companies, family groups, executive teams, client celebrations, and VIP guests. Availability is limited. Inquire via the Hosted Group Tables program or contact us directly to discuss custom host-table configurations.",
  },
  {
    q: "Are tickets refundable?",
    a: "Tickets are non-refundable but are transferable. If you cannot attend, you may transfer your ticket to another guest up to 72 hours before the event by contacting our guest services team.",
  },
];
---

<BaseLayout
  title="Countdown 250 Ball — Homepage Preview | Washington Hilton | July 3, 2026"
  description="Conversion-focused homepage preview for The Official Countdown 250 Ball. Washington Hilton, July 3, 2026. America's premier July 3 celebration."
  ogImage="/images/event/hero-countdown250-toast.png"
>
  <Navbar />

  <main>
    <!-- ============================================================ -->
    <!-- 1. HERO -->
    <!-- ============================================================ -->
    <section class="relative min-h-[100vh] flex items-center justify-center overflow-hidden">
      <!-- Background image -->
      <div class="absolute inset-0">
        <img
          src="/images/event/hero-countdown250-toast.png"
          alt="Black-tie guests toasting with champagne as Countdown 250 reaches 00:00:01 on stage"
          class="w-full h-full object-cover object-center"
        />
        <div class="absolute inset-0" style="background: rgba(0,0,0,0.55);"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 text-center px-4 sm:px-6 max-w-5xl mx-auto pt-28 pb-20">
        <!-- Seal logo -->
        <div class="flex justify-center mb-8 animate-fade-in">
          <img
            src="/images/logos/countdown250-seal-circle-dark.png"
            alt="The Official Countdown 250 Ball — July 3, 2026 — Washington, D.C."
            class="w-[240px] sm:w-[300px] md:w-[340px] h-auto drop-shadow-2xl"
          />
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-4 leading-tight font-heading">
          America's Premier<br class="hidden sm:block" /> July 3 Countdown Celebration
        </h1>

        <p class="text-2xl sm:text-3xl md:text-4xl text-gold font-bold font-heading mb-4 tracking-wide">
          The Official COUNTDOWN 250 Ball
        </p>

        <p class="text-lg sm:text-xl md:text-2xl text-white/95 font-light mb-3 max-w-3xl mx-auto leading-relaxed">
          Kicking off the biggest patriotic weekend in American history.
        </p>

        <p class="text-base sm:text-lg md:text-xl text-white/75 font-light mb-6 max-w-3xl mx-auto leading-relaxed">
          Midnight Countdown to America's 250th Independence Weekend
        </p>

        <p class="text-gold/90 text-sm sm:text-base italic mb-10">
          From the producers of landmark national celebrations for over 30 years.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a
            href={ticketUrl}
            class="eventbrite-checkout bg-red hover:bg-red-light text-white px-10 py-4 text-lg font-semibold tracking-wider uppercase transition-all rounded shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          >
            Get Tickets
          </a>
          <a
            href="#statesman"
            class="border-2 border-gold text-gold hover:bg-gold hover:text-navy-dark px-10 py-4 text-lg font-semibold tracking-wider uppercase transition-all rounded"
          >
            Explore Statesman's Experience
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 1.5 TRUST BAND — two-line elegant text treatment -->
    <!-- ============================================================ -->
    <section class="relative bg-white border-y border-gold/30">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-7 text-center space-y-2">
        <p class="text-navy text-sm sm:text-[15px] font-medium tracking-wide">
          Washington Hilton <span class="text-gold mx-3">&#10022;</span> Supporting Operation Renewed Hope Foundation
        </p>
        <p class="text-navy text-sm sm:text-[15px] font-medium tracking-wide">
          A Once-in-a-Generation Evening <span class="text-gold mx-3">&#10022;</span> Welcoming Guests of All Backgrounds
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 2. STATESMAN'S CONCIERGE PASS SPOTLIGHT -->
    <!-- ============================================================ -->
    <section id="statesman" class="relative py-20 sm:py-28 bg-gradient-to-b from-navy-dark via-navy to-navy-dark text-white overflow-hidden">
      <!-- Gold edge accents -->
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Image -->
          <div class="relative order-2 md:order-1">
            <div class="rounded-lg overflow-hidden shadow-2xl aspect-[4/3] bg-navy/50 border border-gold/30 flex items-center justify-center">
              <img
                src="/images/event/statesman-vip-dinner.png"
                alt="Intimate VIP dinner experience at the Statesman's Concierge tier"
                class="w-full h-full object-cover"
              />
            </div>
            <!-- Gold corner accents -->
            <div class="absolute -top-3 -left-3 w-16 h-16 border-t-2 border-l-2 border-gold/50"></div>
            <div class="absolute -bottom-3 -right-3 w-16 h-16 border-b-2 border-r-2 border-gold/50"></div>
          </div>

          <!-- Text -->
          <div class="order-1 md:order-2">
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-3 font-heading">Statesman's Concierge Pass</h2>
            <p class="text-xl sm:text-2xl text-gold/90 italic font-light mb-6">The pinnacle Countdown 250 experience.</p>

            <p class="text-white/85 text-lg leading-relaxed mb-7">
              For guests seeking one of the most extraordinary evenings of their lives. Ideal for couples, executives, hosts, and guests who expect the best.
            </p>

            <p class="text-red/90 text-sm tracking-[0.2em] uppercase font-semibold mb-8">
              Limited to a select allocation &mdash; tracking toward early sellout
            </p>

            <ul class="space-y-2.5 mb-6">
              {[
                "Priority entry with personal concierge service throughout the night",
                "Upgraded culinary and premium beverage experience all evening",
                "Access to exclusive entertainment areas and elevated experiences",
                "Private tour of historic spaces reserved for presidents and dignitaries",
                "Premium limited-edition official event gift",
                "Recognition in the official program and personal stage acknowledgments",
                "Option to host your Party Inside the Party",
              ].map((b) => (
                <li class="flex items-start text-white/90 text-[15px] leading-snug">
                  <svg class="w-5 h-5 mt-0.5 mr-3 flex-shrink-0 text-gold" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                  </svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>

            <!-- View Full Benefits modal trigger -->
            <button
              type="button"
              id="statesman-benefits-trigger"
              class="group inline-flex items-center gap-2 text-gold hover:text-white text-sm font-semibold tracking-wide transition-colors mb-10"
            >
              <span class="underline underline-offset-4 decoration-gold/40 group-hover:decoration-gold">View Full Statesman's Concierge Pass Benefits &amp; Amenities</span>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </button>

            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href={ticketUrl}
                class="eventbrite-checkout inline-flex items-center justify-center gap-2 bg-gold text-navy-dark hover:bg-gold/90 px-9 py-4 text-sm font-bold tracking-[0.12em] uppercase transition-all rounded ring-1 ring-gold/30 ring-offset-2 ring-offset-navy shadow-xl hover:shadow-2xl hover:-translate-y-0.5 text-center"
              >
                <span class="text-navy-dark">&#9733;</span>
                <span>Secure Statesman's Concierge Passes</span>
              </a>
              <a
                href="/hosted-group-tables"
                class="border-2 border-gold/60 text-gold hover:bg-gold/10 px-8 py-4 text-sm font-semibold tracking-wider uppercase transition-all rounded text-center"
              >
                Hosted Tables Available
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 3. EVENT ENERGY -->
    <!-- ============================================================ -->
    <section class="py-20 sm:py-28 bg-cream">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 sm:mb-16">
          <p class="text-red font-medium tracking-[0.3em] uppercase text-xs mb-4">The Night of the Generation</p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-4 font-heading">One Unforgettable Night</h2>
          <div class="w-20 h-1 bg-red mx-auto"></div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
          {energyFeatures.map((f) => (
            <div class="bg-white rounded-xl border border-gold/20 p-6 text-center hover:border-gold/60 hover:-translate-y-1 transition-all shadow-sm">
              <p class="text-navy font-bold text-lg sm:text-xl font-heading">{f.label}</p>
            </div>
          ))}
          <!-- Featured larger tile centered on the last row -->
          <div class="col-span-2 sm:col-span-3 lg:col-span-4 bg-navy rounded-xl p-8 sm:p-10 text-center text-white mt-2">
            <p class="text-gold font-medium tracking-[0.3em] uppercase text-xs mb-3">At the Stroke of Midnight</p>
            <p class="text-2xl sm:text-3xl font-bold font-heading mb-2">The Countdown to America's 250th</p>
            <p class="text-white/70 text-sm sm:text-base">A once-in-a-lifetime moment in front of thousands of guests and a national audience.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 4. TICKET LADDER -->
    <!-- ============================================================ -->
    <section id="tickets" class="py-20 sm:py-28 bg-navy-dark text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-3">Early Release Pricing</p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-6 font-heading">Choose Your Ticket Type</h2>
          <div class="w-20 h-1 bg-red mx-auto mb-6"></div>
          <p class="text-white/60 text-sm max-w-lg mx-auto">
            Ticket sales are deliberately limited to ensure optimal comfort and an exceptional experience for every guest.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
          {tiers.map((t) => (
            <div class={`relative rounded-2xl overflow-hidden flex flex-col ${
              t.highlight
                ? 'bg-white text-slate ring-4 ring-gold shadow-2xl scale-[1.03]'
                : 'bg-white/5 border-2 border-white/15 text-white'
            }`}>
              <div class={`py-2 text-center text-xs font-bold tracking-widest uppercase ${
                t.highlight ? 'bg-gold text-navy-dark' : 'bg-white/10 text-white/60'
              }`}>
                {t.badge}
              </div>
              <div class="p-8 flex flex-col flex-grow">
                <h3 class={`text-2xl font-bold mb-2 font-heading ${t.highlight ? 'text-navy' : 'text-white'}`}>{t.name}</h3>
                <p class={`italic mb-4 ${t.highlight ? 'text-slate/70' : 'text-white/60'}`}>{t.tagline}</p>
                <p class={`text-4xl font-bold mb-2 ${t.highlight ? 'text-navy' : 'text-white'}`}>{t.price}</p>
                <p class={`text-xs uppercase tracking-[0.15em] font-semibold mb-4 ${t.highlight ? 'text-red/90' : 'text-gold/80'}`}>
                  {t.scarcity}
                </p>
                {t.bullets ? (
                  <ul class={`space-y-2 mb-8 flex-grow ${t.highlight ? 'text-slate/80' : 'text-white/70'}`}>
                    {t.bullets.map((b) => (
                      <li class="flex items-start gap-2 text-sm leading-snug">
                        <svg class={`w-4 h-4 mt-0.5 flex-shrink-0 ${t.highlight ? 'text-gold' : 'text-gold/80'}`} fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                        </svg>
                        <span>{b}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class={`text-sm leading-relaxed mb-8 flex-grow ${t.highlight ? 'text-slate/80' : 'text-white/70'}`}>
                    {t.description}
                  </p>
                )}
                <a
                  href={ticketUrl}
                  class={`eventbrite-checkout block w-full text-center py-3.5 px-6 rounded-lg font-semibold text-sm tracking-wider uppercase transition-all hover:-translate-y-0.5 ${
                    t.highlight
                      ? 'bg-red text-white hover:bg-red-light shadow-lg'
                      : 'bg-white/10 text-white hover:bg-white/20 border border-white/20'
                  }`}
                >
                  Get Tickets
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 5. HOSTED TABLES -->
    <!-- ============================================================ -->
    <section class="py-20 sm:py-28 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Text -->
          <div>
            <p class="text-gold font-medium tracking-[0.3em] uppercase text-xs mb-4">The Hosted Table Experience</p>
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-3 font-heading">Host Your Own Party Within the Party</h2>
            <p class="text-slate/70 italic text-lg mb-5">You invite guests. Guests purchase their own tickets. We handle the rest.</p>
            <div class="w-16 h-1 bg-red mb-6"></div>
            <p class="text-slate/80 text-lg leading-relaxed mb-6">
              Simply invite friends, clients, family, alumni, or colleagues to gather at your reserved hosted table(s) inside the <strong class="text-navy">Statesman's Concierge Area</strong>. Groups of all sizes are welcome. We handle the details while you get the credit. Your group enjoys memories that last a lifetime.
            </p>

            <!-- Benefits callout -->
            <div class="bg-cream border-l-4 border-gold rounded-r-lg p-5 sm:p-6 mb-6">
              <p class="text-navy font-bold text-sm tracking-[0.15em] uppercase mb-3">Hosted Table Benefits</p>
              <ul class="space-y-1.5 text-slate/85 text-[15px] leading-snug">
                <li class="flex items-start"><span class="text-gold mr-2.5 font-bold flex-shrink-0">&bull;</span><span>Reserved premium gathering place for your group</span></li>
                <li class="flex items-start"><span class="text-gold mr-2.5 font-bold flex-shrink-0">&bull;</span><span>Guests purchase their own qualifying tickets</span></li>
                <li class="flex items-start"><span class="text-gold mr-2.5 font-bold flex-shrink-0">&bull;</span><span>Named table signage</span></li>
                <li class="flex items-start"><span class="text-gold mr-2.5 font-bold flex-shrink-0">&bull;</span><span>Founding Host recognition for qualifying groups</span></li>
                <li class="flex items-start"><span class="text-gold mr-2.5 font-bold flex-shrink-0">&bull;</span><span>Public Toast to the Hosts during the evening</span></li>
                <li class="flex items-start"><span class="text-gold mr-2.5 font-bold flex-shrink-0">&bull;</span><span>Simple coordination &mdash; we handle the details</span></li>
              </ul>
            </div>

            <p class="text-red text-sm italic font-medium mb-8">
              Limited premium table placements available.
            </p>
            <a
              href="/hosted-group-tables"
              class="inline-block bg-navy hover:bg-navy-light text-white px-10 py-4 text-sm font-semibold tracking-wider uppercase transition-all rounded shadow-lg hover:-translate-y-0.5"
            >
              Explore Hosted Tables
            </a>
          </div>

          <!-- Image -->
          <div class="relative">
            <div class="rounded-lg overflow-hidden shadow-xl aspect-[4/3]">
              <img
                src="/images/event/formal-dinner-table.png"
                alt="Elegant hosted dinner table with crystal chandeliers"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-gold/10 rounded-lg -z-10"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 5.5 SOCIAL PROOF — real testimonial, premium card treatment -->
    <!-- ============================================================ -->
    <section class="py-20 sm:py-24 bg-navy text-white relative overflow-hidden">
      <!-- Subtle top/bottom gold accents -->
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>

      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
        <p class="text-gold/80 font-medium tracking-[0.3em] uppercase text-[10px] sm:text-xs mb-6">
          Trusted by longtime guests of the All-American Inaugural Ball
        </p>

        <!-- Large decorative opening quote mark -->
        <svg class="w-12 h-12 sm:w-14 sm:h-14 text-gold/70 mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
        </svg>

        <p class="text-xl sm:text-2xl md:text-3xl font-heading font-light italic leading-relaxed mb-10">
          For over twenty years, I&rsquo;ve attended these landmark Washington celebrations and each has delivered unforgettable experiences, exceptional hospitality, and lasting memories. I&rsquo;ve even had the privilege of meeting heroes like Buzz Aldrin. Countdown 250 promises to be another extraordinary night.
        </p>

        <div class="w-16 h-px bg-gold/60 mx-auto mb-5"></div>

        <p class="text-white text-lg font-semibold font-heading mb-1">John Whitbeck</p>
        <p class="text-gold/80 text-sm">Managing Partner, WhitbeckBeglis Law Firm</p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 6. TRUST / LEGITIMACY -->
    <!-- ============================================================ -->
    <section class="py-20 sm:py-28 bg-cream">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <p class="text-gold font-medium tracking-[0.3em] uppercase text-xs mb-4">The Reasons It Matters</p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-navy mb-5 font-heading">Why Guests Attend</h2>
          <div class="w-20 h-1 bg-red mx-auto"></div>
        </div>

        <div class="grid sm:grid-cols-2 gap-6 lg:gap-8">
          {trustPoints.map((p) => (
            <div class="bg-white rounded-xl p-6 sm:p-8 border-l-4 border-gold shadow-sm">
              <h3 class="text-navy font-bold text-xl mb-3 font-heading">{p.title}</h3>
              <p class="text-slate/80 leading-relaxed">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
