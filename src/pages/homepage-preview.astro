      "Premium open bars",
      "Live bands & DJs",
      "Midnight countdown to America's 250th",
    ],
    scarcity: "Current Release Pricing",
    highlight: false,
    badge: "Tier 1",
  },
  {
    name: "Patriot VIP Experience",
    tagline: "Earlier entry and upgraded hospitality.",
    price: "$450",
    bullets: [
      "Everything in Liberty",
      "Early entry + VIP reception dinner",
      "Premium open bar",
      "Access to honored guests",
    ],
    scarcity: "Limited VIP Availability",
    highlight: false,
    badge: "Tier 2",
  },
  {
