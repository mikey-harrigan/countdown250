<script>
  // Statesman benefits modal
  const sBTrigger = document.getElementById('statesman-benefits-trigger');
  const sBModal = document.getElementById('statesman-benefits-modal');
  const sBClose = document.getElementById('statesman-benefits-close');

  function sBOpen() {
    sBModal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function sBCloseFn() {
    sBModal?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  sBTrigger?.addEventListener('click', sBOpen);
  sBClose?.addEventListener('click', sBCloseFn);

  // Click backdrop to close
  sBModal?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.hasAttribute('data-modal-backdrop')) {
      sBCloseFn();
    }
  });

  // ESC key to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sBModal && !sBModal.classList.contains('hidden')) {
      sBCloseFn();
    }
  });
</script>

