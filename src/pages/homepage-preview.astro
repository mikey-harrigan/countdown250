  { icon: "drink",     title: "Premium Open Bars",           desc: "Artisanal cocktails and top-shelf selections all night" },
  { icon: "food",      title: "Culinary Stations",           desc: "Exquisite food prepared by premier chefs" },
  { icon: "star",      title: "Hero Awards",                 desc: "All-American Hero Lifetime Achievement Awards ceremony" },
  { icon: "sparkle",   title: "Midnight Countdown",          desc: "A historic countdown to America's 250th birthday" },
  { icon: "camera",    title: "Immersive Experiences",       desc: "Roaming entertainers, interactive attractions, and more" },
