---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Entertainment | All-American Countdown 250 Ball" description="Live entertainment lineup for the All-American Countdown 250 Ball on July 3, 2026 at the Washington Hilton." ogImage="/images/event/diverse-live-band.png">
  <Navbar />
  <main>
    <section class="relative pt-32 pb-20 bg-navy text-white overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-navy-dark/90 to-navy"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <p class="text-gold font-medium tracking-[0.2em] uppercase text-sm mb-4">Bands, DJs & Performers</p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-4 font-heading">Entertainment</h1>
        <div class="w-20 h-1 bg-red mx-auto"></div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold text-navy mb-6 font-heading">A Night of Unforgettable Entertainment</h2>
          <div class="w-16 h-1 bg-gold mx-auto"></div>
        </div>

        <div class="text-slate/70 text-lg leading-relaxed space-y-6 mb-16">
          <p>
            The All-American Countdown 250 Ball will feature a spectacular lineup of live entertainment
            across <strong class="text-navy">4 stages</strong> and <strong class="text-navy">6 party zones</strong> —
            ensuring an electrifying atmosphere from the moment you arrive until the final note at 1 AM.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-6 mb-16">
          <div class="bg-cream rounded-xl p-6">
            <div class="text-3xl mb-3">🎵</div>
            <h3 class="text-lg font-bold text-navy mb-2">Multiple Live Bands</h3>
            <p class="text-slate/60 text-sm">Top-tier bands performing across multiple stages throughout the evening.</p>
          </div>
          <div class="bg-cream rounded-xl p-6">
            <div class="text-3xl mb-3">🎧</div>
            <h3 class="text-lg font-bold text-navy mb-2">DJs & Dance Floors</h3>
            <p class="text-slate/60 text-sm">High-energy DJs keeping the dance floors packed all night long.</p>
          </div>
          <div class="bg-cream rounded-xl p-6">
            <div class="text-3xl mb-3">🎭</div>
            <h3 class="text-lg font-bold text-navy mb-2">Immersive Experiences</h3>
            <p class="text-slate/60 text-sm">Roaming entertainers and immersive performances creating unforgettable moments.</p>
          </div>
          <div class="bg-cream rounded-xl p-6">
            <div class="text-3xl mb-3">🇺🇸</div>
            <h3 class="text-lg font-bold text-navy mb-2">Tribute to America</h3>
            <p class="text-slate/60 text-sm">Stirring patriotic performances honoring 250 years of American history.</p>
          </div>
        </div>

        <div class="bg-navy rounded-2xl p-10 text-center">
          <svg class="w-12 h-12 text-gold mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
          <h3 class="text-xl font-bold text-gold mb-3">Major Announcements Coming Soon</h3>
          <p class="text-white/70 text-lg mb-6">
            We are finalizing an extraordinary entertainment lineup. Performer announcements will be made in the coming weeks.
          </p>
          <p class="text-white/40 text-sm">Follow us on social media and check our <a href="/updates/" class="text-gold hover:text-gold/80 underline">News & Updates</a> page for the latest announcements.</p>
        </div>

        <div class="text-center mt-12">
          <a href="/#tickets" class="inline-block bg-red hover:bg-red-light text-white px-8 py-3 text-sm font-semibold tracking-wider uppercase transition-all rounded shadow-lg hover:-translate-y-0.5">
            Get Your Tickets
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
